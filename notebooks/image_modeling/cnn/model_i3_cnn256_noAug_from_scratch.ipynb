   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"id\": \"initial_id\",\n",
    "   \"metadata\": {\n",
    "    \"collapsed\": true\n",
    "   },\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# ============================================================\\n\",\n",
    "    \"# @title Model C (without Aug)2\\n\",\n",
    "    \"# CNN from scratch - 256x256 - WITHOUT augmentation\\n\",\n",
    "    \"# FULL STATE CHECKPOINTING (local + Drive)\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import copy\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"from torch.utils.data import Dataset, DataLoader\\n\",\n",
    "    \"from torchvision import transforms\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"from sklearn.metrics import accuracy_score, f1_score, classification_report, confusion_matrix\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# LOCAL_RUN_NAME = \\\"cnn_scratch_256_without_aug_2\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOCAL_RUN_NAME = \\\"model_i3_cnn256_noAug_from_scratch\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"MODEL_NAME = \\\"cnn_scratch_256_without_aug_2\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent\\n\",\n",
    "    \"LOCAL_DATA_DIR = BASE_DIR / \\\"data\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR_BASE = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"MODEL_DIR_BASE = BASE_DIR / \\\"data\\\" / \\\"models\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"MODEL_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# LOAD DATA\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"train_df = pd.read_csv(SPLIT_DIR / \\\"train_split.csv\\\")\\n\",\n",
    "    \"val_df = pd.read_csv(SPLIT_DIR / \\\"val_split.csv\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(SPLIT_DIR / \\\"label2id.json\\\") as f:\\n\",\n",
    "    \"    label2id = {int(k): int(v) for k, v in json.load(f).items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Reproducibility\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"torch.cuda.manual_seed_all(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Device\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"device = torch.device(\\\"cuda\\\" if torch.cuda.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"print(\\\"Using device:\\\", device)\\n\",\n",
    "    \"if torch.cuda.is_available():\\n\",\n",
    "    \"    print(\\\"GPU:\\\", torch.cuda.get_device_name(0))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Local save dirs for this run\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# LOCAL_RUN_NAME = \\\"cnn_scratch_128_with_aug_2\\\"\\n\",\n",
    "    \"LOCAL_RUN_NAME = \\\"model_i1_cnn_128_moderateAug_from_scratch\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOCAL_OUTPUT_ROOT = BASE_DIR / \\\"outputs\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"LOCAL_MODEL_ROOT = LOCAL_DATA_DIR / \\\"models\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"\\n\",\n",
    "    \"for d in [\\n\",\n",
    "    \"    LOCAL_OUTPUT_ROOT, LOCAL_MODEL_ROOT,\\n\",\n",
    "    \"]:\\n\",\n",
    "    \"    d.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Local output root:\\\", LOCAL_OUTPUT_ROOT)\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Parameters\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"IMAGE_SIZE = 256\\n\",\n",
    "    \"BATCH_SIZE = 64\\n\",\n",
    "    \"NUM_WORKERS = 2\\n\",\n",
    "    \"MAX_EPOCHS = 35\\n\",\n",
    "    \"EARLY_STOPPING_PATIENCE = 10\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Set this to True if you want to resume from last checkpoint automatically\\n\",\n",
    "    \"RESUME_TRAINING = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Transforms\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"train_transform_C = transforms.Compose([\\n\",\n",
    "    \"    transforms.Resize((IMAGE_SIZE ,IMAGE_SIZE)),\\n\",\n",
    "    \"    transforms.ToTensor(),\\n\",\n",
    "    \"    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_transform_C = transforms.Compose([\\n\",\n",
    "    \"    transforms.Resize((IMAGE_SIZE , IMAGE_SIZE )),\\n\",\n",
    "    \"    transforms.ToTensor(),\\n\",\n",
    "    \"    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Dataset\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"class RakutenImageDataset(Dataset):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Simple image dataset for Rakuten product images.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Each item returns:\\n\",\n",
    "    \"    - transformed image tensor\\n\",\n",
    "    \"    - integer class label\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Expected dataframe columns:\\n\",\n",
    "    \"    - image_path_local\\n\",\n",
    "    \"    - label_id\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    def __init__(self, df, transform=None):\\n\",\n",
    "    \"        self.df = df.reset_index(drop=True)\\n\",\n",
    "    \"        self.transform = transform\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __len__(self):\\n\",\n",
    "    \"        return len(self.df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __getitem__(self, idx):\\n\",\n",
    "    \"        img_path = self.df.loc[idx, \\\"image_path_local\\\"]\\n\",\n",
    "    \"        label = int(self.df.loc[idx, \\\"label_id\\\"])\\n\",\n",
    "    \"        image = Image.open(img_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.transform:\\n\",\n",
    "    \"            image = self.transform(image)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return image, label\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_dataset_C = RakutenImageDataset(train_df, transform=train_transform_C)\\n\",\n",
    "    \"val_dataset_C = RakutenImageDataset(val_df, transform=val_transform_C)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_loader_C = DataLoader(\\n\",\n",
    "    \"    train_dataset_C,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=True,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=True\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_loader_C = DataLoader(\\n\",\n",
    "    \"    val_dataset_C,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=False,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=True\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Model\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"class ScratchCNN256(nn.Module):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    CNN from scratch for 256x256 RGB images.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Architecture:\\n\",\n",
    "    \"    - 4 convolutional blocks with BatchNorm + ReLU + MaxPool\\n\",\n",
    "    \"    - adaptive average pooling\\n\",\n",
    "    \"    - small MLP classifier head\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    def __init__(self, num_classes=27):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.features = nn.Sequential(\\n\",\n",
    "    \"            nn.Conv2d(3,32,3,padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(32),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Conv2d(32,32,3,padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(32),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.MaxPool2d(2),\\n\",\n",
    "    \"\\n\",\n",
    "    \"            nn.Conv2d(32,64,3,padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(64),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Conv2d(64,64,3,padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(64),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.MaxPool2d(2),\\n\",\n",
    "    \"\\n\",\n",
    "    \"            nn.Conv2d(64,128,3,padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(128),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Conv2d(128,128,3,padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(128),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.MaxPool2d(2),\\n\",\n",
    "    \"\\n\",\n",
    "    \"            nn.Conv2d(128,256,3,padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(256),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Conv2d(256,256,3,padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(256),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.MaxPool2d(2),\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.pool = nn.AdaptiveAvgPool2d((1,1))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.classifier = nn.Sequential(\\n\",\n",
    "    \"            nn.Flatten(),\\n\",\n",
    "    \"            nn.Linear(256,256),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Dropout(0.5),\\n\",\n",
    "    \"            nn.Linear(256,num_classes)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, x):\\n\",\n",
    "    \"        x = self.features(x)\\n\",\n",
    "    \"        x = self.pool(x)\\n\",\n",
    "    \"        x = self.classifier(x)\\n\",\n",
    "    \"        return x\\n\",\n",
    "    \"\\n\",\n",
    "    \"model_C = ScratchCNN256(num_classes=len(label2id)).to(device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Training setup\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"criterion = nn.CrossEntropyLoss()\\n\",\n",
    "    \"\\n\",\n",
    "    \"optimizer = torch.optim.AdamW(\\n\",\n",
    "    \"    model_C.parameters(),\\n\",\n",
    "    \"    lr=5e-4,\\n\",\n",
    "    \"    weight_decay=1e-4\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\\n\",\n",
    "    \"    optimizer,\\n\",\n",
    "    \"    mode=\\\"max\\\",\\n\",\n",
    "    \"    factor=0.5,\\n\",\n",
    "    \"    patience=3,\\n\",\n",
    "    \"    min_lr=1e-6\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Checkpoint paths\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"LAST_CKPT_LOCAL = LOCAL_MODEL_ROOT / \\\"last_checkpoint.pt\\\"\\n\",\n",
    "    \"BEST_CKPT_LOCAL = LOCAL_MODEL_ROOT / \\\"best_checkpoint.pt\\\"\\n\",\n",
    "    \"BEST_WEIGHTS_LOCAL = LOCAL_MODEL_ROOT / \\\"best_model_state_dict.pt\\\"\\n\",\n",
    "    \"HISTORY_LOCAL = LOCAL_OUTPUT_ROOT / \\\"history.csv\\\"\\n\",\n",
    "    \"METADATA_LOCAL = LOCAL_OUTPUT_ROOT / \\\"run_metadata.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Helper: save checkpoint\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"def save_full_checkpoint(\\n\",\n",
    "    \"    checkpoint_path,\\n\",\n",
    "    \"    epoch,\\n\",\n",
    "    \"    model,\\n\",\n",
    "    \"    optimizer,\\n\",\n",
    "    \"    scheduler,\\n\",\n",
    "    \"    history,\\n\",\n",
    "    \"    best_f1,\\n\",\n",
    "    \"    best_epoch,\\n\",\n",
    "    \"    model_name,\\n\",\n",
    "    \"    y_true=None,\\n\",\n",
    "    \"    y_pred=None\\n\",\n",
    "    \"):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Save the full training state needed to resume training exactly.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Saved content:\\n\",\n",
    "    \"    - epoch\\n\",\n",
    "    \"    - model state_dict\\n\",\n",
    "    \"    - optimizer state_dict\\n\",\n",
    "    \"    - scheduler state_dict\\n\",\n",
    "    \"    - history\\n\",\n",
    "    \"    - best validation F1 and epoch\\n\",\n",
    "    \"    - model name\\n\",\n",
    "    \"    - RNG states for reproducibility / resuming\\n\",\n",
    "    \"    - optional last validation true/pred labels\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    checkpoint = {\\n\",\n",
    "    \"        \\\"epoch\\\": epoch,\\n\",\n",
    "    \"        \\\"model_state_dict\\\": model.state_dict(),\\n\",\n",
    "    \"        \\\"optimizer_state_dict\\\": optimizer.state_dict(),\\n\",\n",
    "    \"        \\\"scheduler_state_dict\\\": scheduler.state_dict(),\\n\",\n",
    "    \"        \\\"history\\\": history,\\n\",\n",
    "    \"        \\\"best_f1\\\": best_f1,\\n\",\n",
    "    \"        \\\"best_epoch\\\": best_epoch,\\n\",\n",
    "    \"        \\\"model_name\\\": model_name,\\n\",\n",
    "    \"        \\\"torch_rng_state\\\": torch.get_rng_state(),\\n\",\n",
    "    \"        \\\"numpy_rng_state\\\": np.random.get_state(),\\n\",\n",
    "    \"        \\\"python_rng_state\\\": random.getstate(),\\n\",\n",
    "    \"        \\\"y_true_last_val\\\": y_true,\\n\",\n",
    "    \"        \\\"y_pred_last_val\\\": y_pred,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if torch.cuda.is_available():\\n\",\n",
    "    \"        checkpoint[\\\"cuda_rng_state_all\\\"] = torch.cuda.get_rng_state_all()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    torch.save(checkpoint, checkpoint_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Helper: copy file\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"def copy_to_drive(local_path):\\n\",\n",
    "    \"    shutil.copy2(local_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Helper: save history and metadata\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"def save_training_artifacts(history, best_f1, best_epoch, total_minutes):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Save lightweight run artifacts:\\n\",\n",
    "    \"    - history.csv\\n\",\n",
    "    \"    - metadata json\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    history_df = pd.DataFrame(\\n\",\n",
    "    \"        history,\\n\",\n",
    "    \"        columns=[\\\"epoch\\\", \\\"train_loss\\\", \\\"val_loss\\\", \\\"train_acc\\\", \\\"val_acc\\\", \\\"train_f1\\\", \\\"val_f1\\\"]\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    history_df.to_csv(HISTORY_LOCAL, index=False)\\n\",\n",
    "    \"    copy_to_drive(HISTORY_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    metadata = {\\n\",\n",
    "    \"        \\\"model_name\\\": MODEL_NAME,\\n\",\n",
    "    \"        \\\"image_size\\\": IMAGE_SIZE,\\n\",\n",
    "    \"        \\\"batch_size\\\": BATCH_SIZE,\\n\",\n",
    "    \"        \\\"max_epochs\\\": MAX_EPOCHS,\\n\",\n",
    "    \"        \\\"early_stopping_patience\\\": EARLY_STOPPING_PATIENCE,\\n\",\n",
    "    \"        \\\"best_epoch\\\": int(best_epoch),\\n\",\n",
    "    \"        \\\"best_macro_f1\\\": float(best_f1),\\n\",\n",
    "    \"        \\\"training_minutes\\\": float(total_minutes),\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with open(METADATA_LOCAL, \\\"w\\\") as f:\\n\",\n",
    "    \"        json.dump(metadata, f, indent=2)\\n\",\n",
    "    \"    copy_to_drive(METADATA_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Helper: load checkpoint\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"def load_full_checkpoint(checkpoint_path, model, optimizer, scheduler, device):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Load a full checkpoint and restore training state.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Returns:\\n\",\n",
    "    \"    - start_epoch\\n\",\n",
    "    \"    - history\\n\",\n",
    "    \"    - best_f1\\n\",\n",
    "    \"    - best_epoch\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    checkpoint = torch.load(checkpoint_path, map_location=device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    model.load_state_dict(checkpoint[\\\"model_state_dict\\\"])\\n\",\n",
    "    \"    optimizer.load_state_dict(checkpoint[\\\"optimizer_state_dict\\\"])\\n\",\n",
    "    \"    scheduler.load_state_dict(checkpoint[\\\"scheduler_state_dict\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Restore RNG states if available\\n\",\n",
    "    \"    if \\\"torch_rng_state\\\" in checkpoint:\\n\",\n",
    "    \"        torch.set_rng_state(checkpoint[\\\"torch_rng_state\\\"])\\n\",\n",
    "    \"    if \\\"numpy_rng_state\\\" in checkpoint:\\n\",\n",
    "    \"        np.random.set_state(checkpoint[\\\"numpy_rng_state\\\"])\\n\",\n",
    "    \"    if \\\"python_rng_state\\\" in checkpoint:\\n\",\n",
    "    \"        random.setstate(checkpoint[\\\"python_rng_state\\\"])\\n\",\n",
    "    \"    if torch.cuda.is_available() and \\\"cuda_rng_state_all\\\" in checkpoint:\\n\",\n",
    "    \"        torch.cuda.set_rng_state_all(checkpoint[\\\"cuda_rng_state_all\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    start_epoch =  1\\n\",\n",
    "    \"    history = checkpoint.get(\\\"history\\\", [])\\n\",\n",
    "    \"    best_f1 = checkpoint.get(\\\"best_f1\\\", 0.0)\\n\",\n",
    "    \"    best_epoch = checkpoint.get(\\\"best_epoch\\\", 0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Resumed from checkpoint: {checkpoint_path}\\\")\\n\",\n",
    "    \"    print(f\\\"Starting at epoch: {start_epoch}\\\")\\n\",\n",
    "    \"    print(f\\\"Best F1 so far: {best_f1:.4f} at epoch {best_epoch}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return start_epoch, history, best_f1, best_epoch\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Training / validation for one epoch\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"def run_epoch(model, loader, optimizer=None):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Run one full epoch.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    If optimizer is provided -> training mode.\\n\",\n",
    "    \"    If optimizer is None -> evaluation mode.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Returns:\\n\",\n",
    "    \"    - average loss\\n\",\n",
    "    \"    - accuracy\\n\",\n",
    "    \"    - macro F1\\n\",\n",
    "    \"    - true labels\\n\",\n",
    "    \"    - predicted labels\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    train = optimizer is not None\\n\",\n",
    "    \"    model.train() if train else model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    total_loss = 0.0\\n\",\n",
    "    \"    preds_all = []\\n\",\n",
    "    \"    labels_all = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for images, labels in loader:\\n\",\n",
    "    \"        images = images.to(device, non_blocking=True)\\n\",\n",
    "    \"        labels = labels.to(device, non_blocking=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if train:\\n\",\n",
    "    \"            optimizer.zero_grad()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with torch.set_grad_enabled(train):\\n\",\n",
    "    \"            outputs = model(images)\\n\",\n",
    "    \"            loss = criterion(outputs, labels)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if train:\\n\",\n",
    "    \"                loss.backward()\\n\",\n",
    "    \"                optimizer.step()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        total_loss += loss.item() * images.size(0)\\n\",\n",
    "    \"        preds = torch.argmax(outputs, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        preds_all.extend(preds.detach().cpu().numpy())\\n\",\n",
    "    \"        labels_all.extend(labels.detach().cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    epoch_loss = total_loss / len(loader.dataset)\\n\",\n",
    "    \"    epoch_acc = accuracy_score(labels_all, preds_all)\\n\",\n",
    "    \"    epoch_f1 = f1_score(labels_all, preds_all, average=\\\"macro\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return epoch_loss, epoch_acc, epoch_f1, np.array(labels_all), np.array(preds_all)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Resume setup\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"start_epoch = 1\\n\",\n",
    "    \"history = []\\n\",\n",
    "    \"best_f1 = 0.0\\n\",\n",
    "    \"best_epoch = 0\\n\",\n",
    "    \"epochs_without_improvement = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"if RESUME_TRAINING and LAST_CKPT_LOCAL.exists():\\n\",\n",
    "    \"    start_epoch, history, best_f1, best_epoch = load_full_checkpoint(\\n\",\n",
    "    \"        LAST_CKPT_LOCAL,\\n\",\n",
    "    \"        model_C,\\n\",\n",
    "    \"        optimizer,\\n\",\n",
    "    \"        scheduler,\\n\",\n",
    "    \"        device\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    epochs_without_improvement = start_epoch - best_epoch - 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Train\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"start_time = time.time()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for epoch in range(start_epoch, MAX_EPOCHS + 1):\\n\",\n",
    "    \"\\n\",\n",
    "    \"    train_loss, train_acc, train_f1, _, _ = run_epoch(model_C, train_loader_C, optimizer=optimizer)\\n\",\n",
    "    \"    val_loss, val_acc, val_f1, y_true, y_pred = run_epoch(model_C, val_loader_C, optimizer=None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    scheduler.step(val_f1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    history.append([\\n\",\n",
    "    \"        epoch,\\n\",\n",
    "    \"        train_loss,\\n\",\n",
    "    \"        val_loss,\\n\",\n",
    "    \"        train_acc,\\n\",\n",
    "    \"        val_acc,\\n\",\n",
    "    \"        train_f1,\\n\",\n",
    "    \"        val_f1\\n\",\n",
    "    \"    ])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    current_lr = optimizer.param_groups[0][\\\"lr\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(\\n\",\n",
    "    \"        f\\\"Epoch {epoch:02d} | \\\"\\n\",\n",
    "    \"        f\\\"lr={current_lr:.2e} | \\\"\\n\",\n",
    "    \"        f\\\"train_loss={train_loss:.4f} | \\\"\\n\",\n",
    "    \"        f\\\"val_loss={val_loss:.4f} | \\\"\\n\",\n",
    "    \"        f\\\"train_f1={train_f1:.4f} | \\\"\\n\",\n",
    "    \"        f\\\"val_f1={val_f1:.4f}\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Save \\\"last checkpoint\\\" every epoch\\n\",\n",
    "    \"    save_full_checkpoint(\\n\",\n",
    "    \"        checkpoint_path=LAST_CKPT_LOCAL,\\n\",\n",
    "    \"        epoch=epoch,\\n\",\n",
    "    \"        model=model_C,\\n\",\n",
    "    \"        optimizer=optimizer,\\n\",\n",
    "    \"        scheduler=scheduler,\\n\",\n",
    "    \"        history=history,\\n\",\n",
    "    \"        best_f1=best_f1,\\n\",\n",
    "    \"        best_epoch=best_epoch,\\n\",\n",
    "    \"        model_name=MODEL_NAME,\\n\",\n",
    "    \"        y_true=y_true,\\n\",\n",
    "    \"        y_pred=y_pred\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    copy_to_drive(LAST_CKPT_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Save best checkpoint if improved\\n\",\n",
    "    \"    if val_f1 > best_f1:\\n\",\n",
    "    \"        best_f1 = val_f1\\n\",\n",
    "    \"        best_epoch = epoch\\n\",\n",
    "    \"        epochs_without_improvement = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        save_full_checkpoint(\\n\",\n",
    "    \"            checkpoint_path=BEST_CKPT_LOCAL,\\n\",\n",
    "    \"            epoch=epoch,\\n\",\n",
    "    \"            model=model_C,\\n\",\n",
    "    \"            optimizer=optimizer,\\n\",\n",
    "    \"            scheduler=scheduler,\\n\",\n",
    "    \"            history=history,\\n\",\n",
    "    \"            best_f1=best_f1,\\n\",\n",
    "    \"            best_epoch=best_epoch,\\n\",\n",
    "    \"            model_name=MODEL_NAME,\\n\",\n",
    "    \"            y_true=y_true,\\n\",\n",
    "    \"            y_pred=y_pred\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        copy_to_drive(BEST_CKPT_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Also save just weights for lightweight inference\\n\",\n",
    "    \"        torch.save(model_C.state_dict(), BEST_WEIGHTS_LOCAL)\\n\",\n",
    "    \"        copy_to_drive(BEST_WEIGHTS_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"  New best model saved at epoch {epoch} with val_macro_f1={val_f1:.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        epochs_without_improvement += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Save CSV history + metadata after every epoch\\n\",\n",
    "    \"    elapsed_minutes = (time.time() - start_time) / 60\\n\",\n",
    "    \"    save_training_artifacts(\\n\",\n",
    "    \"        history=history,\\n\",\n",
    "    \"        best_f1=best_f1,\\n\",\n",
    "    \"        best_epoch=best_epoch,\\n\",\n",
    "    \"        total_minutes=elapsed_minutes\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Early stopping\\n\",\n",
    "    \"    if epochs_without_improvement >= EARLY_STOPPING_PATIENCE:\\n\",\n",
    "    \"        print(f\\\"Early stopping triggered after {EARLY_STOPPING_PATIENCE} epochs without improvement.\\\")\\n\",\n",
    "    \"        break\\n\",\n",
    "    \"\\n\",\n",
    "    \"end_time = time.time()\\n\",\n",
    "    \"total_minutes = (end_time - start_time) / 60\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nTraining finished.\\\")\\n\",\n",
    "    \"print(\\\"Best epoch:\\\", best_epoch)\\n\",\n",
    "    \"print(\\\"Best macro F1:\\\", best_f1)\\n\",\n",
    "    \"print(\\\"Training minutes:\\\", total_minutes)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Save final metadata one more time with final elapsed time\\n\",\n",
    "    \"save_training_artifacts(\\n\",\n",
    "    \"    history=history,\\n\",\n",
    "    \"    best_f1=best_f1,\\n\",\n",
    "    \"    best_epoch=best_epoch,\\n\",\n",
    "    \"    total_minutes=total_minutes\\n\",\n",
    "    \")\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
