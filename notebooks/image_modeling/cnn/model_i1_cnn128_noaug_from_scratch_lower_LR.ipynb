    "   \"source\": [\n",
    "    \"######################\\n\",\n",
    "    \"# @title CNN 128 (without Aug but lower LR)\\n\",\n",
    "    \"######################\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import copy\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"import math\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"import gc\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"from torch.utils.data import Dataset, DataLoader\\n\",\n",
    "    \"from torchvision import transforms\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"from sklearn.metrics import (\\n\",\n",
    "    \"    accuracy_score,\\n\",\n",
    "    \"    f1_score,\\n\",\n",
    "    \"    classification_report,\\n\",\n",
    "    \"    confusion_matrix\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOCAL_RUN_NAME = \\\"model_i1_cnn128_noaug_from_scratch_lower_LR\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent\\n\",\n",
    "    \"LOCAL_DATA_DIR = BASE_DIR / \\\"data\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR_BASE = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"MODEL_DIR_BASE = BASE_DIR / \\\"data\\\" / \\\"models\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"FIGURE_DIR_BASE = BASE_DIR / \\\"figures\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"MODEL_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"FIGURE_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# LOAD DATA\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"train_df = pd.read_csv(SPLIT_DIR / \\\"train_split.csv\\\")\\n\",\n",
    "    \"val_df = pd.read_csv(SPLIT_DIR / \\\"val_split.csv\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(SPLIT_DIR / \\\"label2id.json\\\") as f:\\n\",\n",
    "    \"    label2id = {int(k): int(v) for k, v in json.load(f).items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Reproducibility\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"torch.cuda.manual_seed_all(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Device\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"device = torch.device(\\\"cuda\\\" if torch.cuda.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"print(\\\"Using device:\\\", device)\\n\",\n",
    "    \"if torch.cuda.is_available():\\n\",\n",
    "    \"    print(\\\"GPU:\\\", torch.cuda.get_device_name(0))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Local  save dirs for this run\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"LOCAL_RUN_NAME = \\\"cnn_scratch_128_diff_LR\\\"\\n\",\n",
    "    \"LOCAL_OUTPUT_ROOT = BASE_DIR / \\\"outputs\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"\\n\",\n",
    "    \"for d in [\\n\",\n",
    "    \"    LOCAL_OUTPUT_ROOT, MODEL_DIR_BASE,\\n\",\n",
    "    \"]:\\n\",\n",
    "    \"    d.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Local output root:\\\", LOCAL_OUTPUT_ROOT)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Transforms / loaders for MODEL B\\n\",\n",
    "    \"# 128x128, WITHOUT augmentation\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"IMAGE_SIZE = 128\\n\",\n",
    "    \"BATCH_SIZE = 128\\n\",\n",
    "    \"NUM_WORKERS = 2\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_transform_B = transforms.Compose([\\n\",\n",
    "    \"    transforms.Resize((IMAGE_SIZE , IMAGE_SIZE )),\\n\",\n",
    "    \"    transforms.ToTensor(),\\n\",\n",
    "    \"    transforms.Normalize([0.485,0.456,0.406],[0.229,0.224,0.225])\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_transform_B = transforms.Compose([\\n\",\n",
    "    \"    transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),\\n\",\n",
    "    \"    transforms.ToTensor(),\\n\",\n",
    "    \"    transforms.Normalize(\\n\",\n",
    "    \"        mean=[0.485, 0.456, 0.406],\\n\",\n",
    "    \"        std=[0.229, 0.224, 0.225]\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"class RakutenImageDataset(Dataset):\\n\",\n",
    "    \"    def __init__(self, df, transform=None, path_col=\\\"image_path_local\\\", label_col=\\\"label_id\\\"):\\n\",\n",
    "    \"        self.df = df.reset_index(drop=True)\\n\",\n",
    "    \"        self.transform = transform\\n\",\n",
    "    \"        self.path_col = path_col\\n\",\n",
    "    \"        self.label_col = label_col\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __len__(self):\\n\",\n",
    "    \"        return len(self.df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __getitem__(self, idx):\\n\",\n",
    "    \"        img_path = self.df.loc[idx, self.path_col]\\n\",\n",
    "    \"        label = int(self.df.loc[idx, self.label_col])\\n\",\n",
    "    \"        image = Image.open(img_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.transform is not None:\\n\",\n",
    "    \"            image = self.transform(image)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return image, label\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_dataset_B = RakutenImageDataset(train_df, transform=train_transform_B)\\n\",\n",
    "    \"val_dataset_B = RakutenImageDataset(val_df, transform=val_transform_B)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_loader_B = DataLoader(\\n\",\n",
    "    \"    train_dataset_B,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=True,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=torch.cuda.is_available()\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_loader_B = DataLoader(\\n\",\n",
    "    \"    val_dataset_B,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=False,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=torch.cuda.is_available()\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"class ScratchCNN128(nn.Module):\\n\",\n",
    "    \"    def __init__(self, num_classes=27):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.features = nn.Sequential(\\n\",\n",
    "    \"            nn.Conv2d(3, 32, kernel_size=3, padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(32),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.Conv2d(32, 32, kernel_size=3, padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(32),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.MaxPool2d(2),\\n\",\n",
    "    \"            nn.Dropout(0.10),\\n\",\n",
    "    \"\\n\",\n",
    "    \"            nn.Conv2d(32, 64, kernel_size=3, padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(64),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.Conv2d(64, 64, kernel_size=3, padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(64),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.MaxPool2d(2),\\n\",\n",
    "    \"            nn.Dropout(0.15),\\n\",\n",
    "    \"\\n\",\n",
    "    \"            nn.Conv2d(64, 128, kernel_size=3, padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(128),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.Conv2d(128, 128, kernel_size=3, padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(128),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.MaxPool2d(2),\\n\",\n",
    "    \"            nn.Dropout(0.20),\\n\",\n",
    "    \"\\n\",\n",
    "    \"            nn.Conv2d(128, 256, kernel_size=3, padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(256),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.Conv2d(256, 256, kernel_size=3, padding=1),\\n\",\n",
    "    \"            nn.BatchNorm2d(256),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.MaxPool2d(2),\\n\",\n",
    "    \"            nn.Dropout(0.25),\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.pool = nn.AdaptiveAvgPool2d((1, 1))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.classifier = nn.Sequential(\\n\",\n",
    "    \"            nn.Flatten(),\\n\",\n",
    "    \"            nn.Linear(256, 256),\\n\",\n",
    "    \"            nn.ReLU(inplace=True),\\n\",\n",
    "    \"            nn.Dropout(0.40),\\n\",\n",
    "    \"            nn.Linear(256, num_classes)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, x):\\n\",\n",
    "    \"        x = self.features(x)\\n\",\n",
    "    \"        x = self.pool(x)\\n\",\n",
    "    \"        x = self.classifier(x)\\n\",\n",
    "    \"        return x\\n\",\n",
    "    \"\\n\",\n",
    "    \"num_classes = len(label2id)\\n\",\n",
    "    \"model_B = ScratchCNN128(num_classes=num_classes).to(device)\\n\",\n",
    "    \"print(model_B)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Loss, optimizer, scheduler\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"criterion = nn.CrossEntropyLoss()\\n\",\n",
    "    \"INITIAL_LR = 5e-4\\n\",\n",
    "    \"WEIGHT_DECAY = 1e-4\\n\",\n",
    "    \"PATIENCE = 5\\n\",\n",
    "    \"MIN_LR = 1e-6\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Optimizer\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"optimizer = torch.optim.AdamW(\\n\",\n",
    "    \"    model_B.parameters(),\\n\",\n",
    "    \"    lr=INITIAL_LR,          # slower than 1e-3\\n\",\n",
    "    \"    weight_decay=WEIGHT_DECAY\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\\n\",\n",
    "    \"    optimizer,\\n\",\n",
    "    \"    mode=\\\"max\\\",\\n\",\n",
    "    \"    factor=0.5,\\n\",\n",
    "    \"    patience=PATIENCE,       #increase to 5 from 3\\n\",\n",
    "    \"    min_lr=MIN_LR\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Training config\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"MODEL_NAME = \\\"CNN_Scratch_128_diff_LR\\\"\\n\",\n",
    "    \"MAX_EPOCHS = 45\\n\",\n",
    "    \"EARLY_STOPPING_PATIENCE = 15\\n\",\n",
    "    \"\\n\",\n",
    "    \"BEST_CHECKPOINT_LOCAL = MODEL_DIR_BASE / \\\"best_model_b_sum.pt\\\"\\n\",\n",
    "    \"LAST_CHECKPOINT_LOCAL = MODEL_DIR_BASE / \\\"last_checkpoint_b_sum.pt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def save_full_checkpoint(checkpoint, local_path):\\n\",\n",
    "    \"    torch.save(checkpoint, local_path)\\n\",\n",
    "    \"    shutil.copy2(local_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_full_checkpoint(load_path, model, optimizer=None, scheduler=None, device=\\\"cpu\\\"):\\n\",\n",
    "    \"    checkpoint = torch.load(load_path, map_location=device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if \\\"model_state_dict\\\" in checkpoint:\\n\",\n",
    "    \"        model.load_state_dict(checkpoint[\\\"model_state_dict\\\"])\\n\",\n",
    "    \"        if optimizer is not None and \\\"optimizer_state_dict\\\" in checkpoint:\\n\",\n",
    "    \"            optimizer.load_state_dict(checkpoint[\\\"optimizer_state_dict\\\"])\\n\",\n",
    "    \"        if scheduler is not None and \\\"scheduler_state_dict\\\" in checkpoint:\\n\",\n",
    "    \"            scheduler.load_state_dict(checkpoint[\\\"scheduler_state_dict\\\"])\\n\",\n",
    "    \"        return checkpoint\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        model.load_state_dict(checkpoint)\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            \\\"epoch\\\": 0,\\n\",\n",
    "    \"            \\\"best_epoch\\\": 0,\\n\",\n",
    "    \"            \\\"best_macro_f1\\\": -np.inf,\\n\",\n",
    "    \"            \\\"history\\\": []\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"def plot_history(history_df, loss_save_local):\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_loss\\\"], label=\\\"Train Loss\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_loss\\\"], label=\\\"Val Loss\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Loss\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Loss\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(loss_save_local, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    shutil.copy2(loss_save_local)\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_acc\\\"], label=\\\"Train Accuracy\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_acc\\\"], label=\\\"Val Accuracy\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Accuracy\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Accuracy\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    acc_local = loss_save_local.parent / \\\"training_accuracy.png\\\"\\n\",\n",
    "    \"    plt.savefig(acc_local, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    shutil.copy2(acc_local)\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_macro_f1\\\"], label=\\\"Train Macro F1\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_macro_f1\\\"], label=\\\"Val Macro F1\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Macro F1\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Macro F1\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    f1_local = loss_save_local.parent / \\\"training_macro_f1.png\\\"\\n\",\n",
    "    \"    plt.savefig(f1_local, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    shutil.copy2(f1_local)\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def run_epoch(model, loader, criterion, optimizer=None, phase=\\\"train\\\"):\\n\",\n",
    "    \"    is_train = optimizer is not None\\n\",\n",
    "    \"    model.train() if is_train else model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    running_loss = 0.0\\n\",\n",
    "    \"    all_preds = []\\n\",\n",
    "    \"    all_true = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for batch_idx, (images, labels) in enumerate(loader, start=1):\\n\",\n",
    "    \"        images = images.to(device, non_blocking=True)\\n\",\n",
    "    \"        labels = labels.to(device, non_blocking=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if is_train:\\n\",\n",
    "    \"            optimizer.zero_grad()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with torch.set_grad_enabled(is_train):\\n\",\n",
    "    \"            logits = model(images)\\n\",\n",
    "    \"            loss = criterion(logits, labels)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if is_train:\\n\",\n",
    "    \"                loss.backward()\\n\",\n",
    "    \"                optimizer.step()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        running_loss += loss.item() * images.size(0)\\n\",\n",
    "    \"        preds = torch.argmax(logits, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        all_preds.extend(preds.detach().cpu().numpy())\\n\",\n",
    "    \"        all_true.extend(labels.detach().cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if batch_idx == 1 or batch_idx % 100 == 0 or batch_idx == len(loader):\\n\",\n",
    "    \"            print(f\\\"{phase} batch {batch_idx}/{len(loader)} done\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    epoch_loss = running_loss / len(loader.dataset)\\n\",\n",
    "    \"    epoch_acc = accuracy_score(all_true, all_preds)\\n\",\n",
    "    \"    epoch_macro_f1 = f1_score(all_true, all_preds, average=\\\"macro\\\")\\n\",\n",
    "    \"    epoch_weighted_f1 = f1_score(all_true, all_preds, average=\\\"weighted\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return epoch_loss, epoch_acc, epoch_macro_f1, epoch_weighted_f1, np.array(all_true), np.array(all_preds)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def predict_with_proba(model, loader):\\n\",\n",
    "    \"    model.eval()\\n\",\n",
    "    \"    all_probs = []\\n\",\n",
    "    \"    all_preds = []\\n\",\n",
    "    \"    all_true = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with torch.no_grad():\\n\",\n",
    "    \"        for images, labels in loader:\\n\",\n",
    "    \"            images = images.to(device, non_blocking=True)\\n\",\n",
    "    \"            labels = labels.to(device, non_blocking=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            logits = model(images)\\n\",\n",
    "    \"            probs = torch.softmax(logits, dim=1)\\n\",\n",
    "    \"            preds = torch.argmax(probs, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            all_probs.append(probs.cpu().numpy())\\n\",\n",
    "    \"            all_preds.append(preds.cpu().numpy())\\n\",\n",
    "    \"            all_true.append(labels.cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    y_proba = np.concatenate(all_probs)\\n\",\n",
    "    \"    y_pred = np.concatenate(all_preds)\\n\",\n",
    "    \"    y_true = np.concatenate(all_true)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return y_true, y_pred, y_proba\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Train\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"history = []\\n\",\n",
    "    \"best_macro_f1 = -np.inf\\n\",\n",
    "    \"best_epoch = -1\\n\",\n",
    "    \"best_state = None\\n\",\n",
    "    \"epochs_without_improvement = 0\\n\",\n",
    "    \"start_epoch = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"resume_path = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"if LAST_CHECKPOINT_LOCAL.exists():\\n\",\n",
    "    \"    resume_path = LAST_CHECKPOINT_LOCAL\\n\",\n",
    "    \"elif BEST_CHECKPOINT_LOCAL.exists():\\n\",\n",
    "    \"    resume_path = BEST_CHECKPOINT_LOCAL\\n\",\n",
    "    \"\\n\",\n",
    "    \"if resume_path is not None:\\n\",\n",
    "    \"    print(f\\\"Existing checkpoint found: {resume_path}\\\")\\n\",\n",
    "    \"    loaded_ckpt = load_full_checkpoint(\\n\",\n",
    "    \"        resume_path,\\n\",\n",
    "    \"        model_B,\\n\",\n",
    "    \"        optimizer=optimizer,\\n\",\n",
    "    \"        scheduler=scheduler,\\n\",\n",
    "    \"        device=device\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    start_epoch = int(loaded_ckpt.get(\\\"epoch\\\", 0)) + 1\\n\",\n",
    "    \"    history = loaded_ckpt.get(\\\"history\\\", [])\\n\",\n",
    "    \"    best_macro_f1 = float(loaded_ckpt.get(\\\"best_macro_f1\\\", -np.inf))\\n\",\n",
    "    \"    best_epoch = int(loaded_ckpt.get(\\\"best_epoch\\\", -1))\\n\",\n",
    "    \"    epochs_without_improvement = int(loaded_ckpt.get(\\\"epochs_without_improvement\\\", 0))\\n\",\n",
    "    \"    print(f\\\"Resuming from epoch {start_epoch}\\\")\\n\",\n",
    "    \"    print(f\\\"Best epoch so far: {best_epoch}\\\")\\n\",\n",
    "    \"    print(f\\\"Best val macro F1 so far: {best_macro_f1:.6f}\\\")\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(\\\"No checkpoint found. Starting from scratch.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"start_time = time.time()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for epoch in range(start_epoch, MAX_EPOCHS + 1):\\n\",\n",
    "    \"    train_loss, train_acc, train_macro_f1, train_weighted_f1, _, _ = run_epoch(\\n\",\n",
    "    \"        model_B, train_loader_B, criterion, optimizer=optimizer, phase=\\\"train\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    val_loss, val_acc, val_macro_f1, val_weighted_f1, _, _ = run_epoch(\\n\",\n",
    "    \"        model_B, val_loader_B, criterion, optimizer=None, phase=\\\"val\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    scheduler.step(val_macro_f1)\\n\",\n",
    "    \"    current_lr = optimizer.param_groups[0][\\\"lr\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    history.append({\\n\",\n",
    "    \"        \\\"epoch\\\": epoch,\\n\",\n",
    "    \"        \\\"train_loss\\\": train_loss,\\n\",\n",
    "    \"        \\\"train_acc\\\": train_acc,\\n\",\n",
    "    \"        \\\"train_macro_f1\\\": train_macro_f1,\\n\",\n",
    "    \"        \\\"train_weighted_f1\\\": train_weighted_f1,\\n\",\n",
    "    \"        \\\"val_loss\\\": val_loss,\\n\",\n",
    "    \"        \\\"val_acc\\\": val_acc,\\n\",\n",
    "    \"        \\\"val_macro_f1\\\": val_macro_f1,\\n\",\n",
    "    \"        \\\"val_weighted_f1\\\": val_weighted_f1,\\n\",\n",
    "    \"        \\\"lr\\\": current_lr\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(\\n\",\n",
    "    \"        f\\\"Epoch {epoch:02d}/{MAX_EPOCHS} | \\\"\\n\",\n",
    "    \"        f\\\"train_loss={train_loss:.4f} | val_loss={val_loss:.4f} | \\\"\\n\",\n",
    "    \"        f\\\"train_acc={train_acc:.4f} | val_acc={val_acc:.4f} | \\\"\\n\",\n",
    "    \"        f\\\"train_macro_f1={train_macro_f1:.4f} | val_macro_f1={val_macro_f1:.4f} | \\\"\\n\",\n",
    "    \"        f\\\"lr={current_lr:.6f}\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    improved = val_macro_f1 > best_macro_f1\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if improved:\\n\",\n",
    "    \"        best_macro_f1 = val_macro_f1\\n\",\n",
    "    \"        best_epoch = epoch\\n\",\n",
    "    \"        epochs_without_improvement = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        best_checkpoint = {\\n\",\n",
    "    \"            \\\"epoch\\\": epoch,\\n\",\n",
    "    \"            \\\"best_epoch\\\": best_epoch,\\n\",\n",
    "    \"            \\\"best_macro_f1\\\": float(best_macro_f1),\\n\",\n",
    "    \"            \\\"epochs_without_improvement\\\": int(epochs_without_improvement),\\n\",\n",
    "    \"            \\\"model_state_dict\\\": copy.deepcopy(model_B.state_dict()),\\n\",\n",
    "    \"            \\\"optimizer_state_dict\\\": optimizer.state_dict(),\\n\",\n",
    "    \"            \\\"scheduler_state_dict\\\": scheduler.state_dict(),\\n\",\n",
    "    \"            \\\"history\\\": history,\\n\",\n",
    "    \"            \\\"model_name\\\": MODEL_NAME\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"        save_full_checkpoint(best_checkpoint, BEST_CHECKPOINT_LOCAL)\\n\",\n",
    "    \"        print(f\\\"  -> New best model saved at epoch {epoch} (val_macro_f1={val_macro_f1:.4f})\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        epochs_without_improvement += 1\\n\",\n",
    "    \"        print(f\\\"  -> No improvement for {epochs_without_improvement} epoch(s)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    last_checkpoint = {\\n\",\n",
    "    \"        \\\"epoch\\\": epoch,\\n\",\n",
    "    \"        \\\"best_epoch\\\": best_epoch,\\n\",\n",
    "    \"        \\\"best_macro_f1\\\": float(best_macro_f1),\\n\",\n",
    "    \"        \\\"epochs_without_improvement\\\": int(epochs_without_improvement),\\n\",\n",
    "    \"        \\\"model_state_dict\\\": model_B.state_dict(),\\n\",\n",
    "    \"        \\\"optimizer_state_dict\\\": optimizer.state_dict(),\\n\",\n",
    "    \"        \\\"scheduler_state_dict\\\": scheduler.state_dict(),\\n\",\n",
    "    \"        \\\"history\\\": history,\\n\",\n",
    "    \"        \\\"model_name\\\": MODEL_NAME\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"    save_full_checkpoint(last_checkpoint, LAST_CHECKPOINT_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if epochs_without_improvement >= EARLY_STOPPING_PATIENCE:\\n\",\n",
    "    \"        print(f\\\"Early stopping triggered after epoch {epoch}\\\")\\n\",\n",
    "    \"        break\\n\",\n",
    "    \"\\n\",\n",
    "    \"total_time = time.time() - start_time\\n\",\n",
    "    \"print(f\\\"\\\\nTraining finished in {total_time/60:.2f} minutes\\\")\\n\",\n",
    "    \"print(f\\\"Best epoch: {best_epoch}\\\")\\n\",\n",
    "    \"print(f\\\"Best val macro F1: {best_macro_f1:.6f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"if BEST_CHECKPOINT_LOCAL.exists():\\n\",\n",
    "    \"    best_loaded = torch.load(BEST_CHECKPOINT_LOCAL, map_location=device)\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    best_loaded = torch.load(LAST_CHECKPOINT_LOCAL, map_location=device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if \\\"model_state_dict\\\" in best_loaded:\\n\",\n",
    "    \"    model_B.load_state_dict(best_loaded[\\\"model_state_dict\\\"])\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    model_B.load_state_dict(best_loaded)\\n\",\n",
    "    \"\\n\",\n",
    "    \"y_true, y_pred, y_proba = predict_with_proba(model_B, val_loader_B)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Final metrics\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"final_accuracy = accuracy_score(y_true, y_pred)\\n\",\n",
    "    \"final_macro_f1 = f1_score(y_true, y_pred, average=\\\"macro\\\")\\n\",\n",
    "    \"final_weighted_f1 = f1_score(y_true, y_pred, average=\\\"weighted\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"metrics_df = pd.DataFrame([{\\n\",\n",
    "    \"    \\\"model_name\\\": MODEL_NAME,\\n\",\n",
    "    \"    \\\"image_size\\\": IMAGE_SIZE,\\n\",\n",
