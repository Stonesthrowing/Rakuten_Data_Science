    "    \"    \\\"macro_f1\\\": final_macro_f1,\\n\",\n",
    "    \"    \\\"weighted_f1\\\": final_weighted_f1,\\n\",\n",
    "    \"    \\\"training_minutes_this_session\\\": total_time / 60\\n\",\n",
    "    \"}])\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nFinal validation metrics:\\\")\\n\",\n",
    "    \"print(metrics_df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Save metrics/history\\n\",\n",
