    "    \"else:\\n\",\n",
    "    \"    model_H.load_state_dict(best_loaded)\\n\",\n",
    "    \"\\n\",\n",
    "    \"y_true, y_pred, y_proba = predict_with_proba(model_H, val_loader_H)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
