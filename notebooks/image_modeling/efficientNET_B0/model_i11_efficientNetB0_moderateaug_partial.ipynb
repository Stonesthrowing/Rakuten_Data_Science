    "    \"            \\\"scheduler_state_dict\\\": scheduler.state_dict(),\\n\",\n",
    "    \"            \\\"scaler_state_dict\\\": scaler.state_dict(),\\n\",\n",
    "    \"            \\\"history\\\": history,\\n\",\n",
    "    \"            \\\"model_name\\\": MODEL_NAME,\\n\",\n",
    "    \"            \\\"torch_rng_state\\\": torch.get_rng_state(),\\n\",\n",
    "    \"            \\\"numpy_rng_state\\\": np.random.get_state(),\\n\",\n",
    "    \"            \\\"python_rng_state\\\": random.getstate()\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if torch.cuda.is_available():\\n\",\n",
    "    \"            best_checkpoint[\\\"cuda_rng_state_all\\\"] = torch.cuda.get_rng_state_all()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        save_full_checkpoint(best_checkpoint, BEST_CHECKPOINT_LOCAL)\\n\",\n",
    "    \"        torch.save(model_H.state_dict(), BEST_WEIGHTS_LOCAL)\\n\",\n",
    "    \"        shutil.copy2(BEST_WEIGHTS_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"  -> New best model saved at epoch {epoch} (val_macro_f1={val_macro_f1:.4f})\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        epochs_without_improvement += 1\\n\",\n",
    "    \"        print(f\\\"  -> No improvement for {epochs_without_improvement} epoch(s)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    last_checkpoint = {\\n\",\n",
    "    \"        \\\"epoch\\\": epoch,\\n\",\n",
    "    \"        \\\"best_epoch\\\": best_epoch,\\n\",\n",
    "    \"        \\\"best_macro_f1\\\": float(best_macro_f1),\\n\",\n",
    "    \"        \\\"epochs_without_improvement\\\": int(epochs_without_improvement),\\n\",\n",
    "    \"        \\\"model_state_dict\\\": model_H.state_dict(),\\n\",\n",
    "    \"        \\\"optimizer_state_dict\\\": optimizer.state_dict(),\\n\",\n",
    "    \"        \\\"scheduler_state_dict\\\": scheduler.state_dict(),\\n\",\n",
    "    \"        \\\"scaler_state_dict\\\": scaler.state_dict(),\\n\",\n",
    "    \"        \\\"history\\\": history,\\n\",\n",
    "    \"        \\\"model_name\\\": MODEL_NAME,\\n\",\n",
    "    \"        \\\"torch_rng_state\\\": torch.get_rng_state(),\\n\",\n",
    "    \"        \\\"numpy_rng_state\\\": np.random.get_state(),\\n\",\n",
    "    \"        \\\"python_rng_state\\\": random.getstate()\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if torch.cuda.is_available():\\n\",\n",
    "    \"        last_checkpoint[\\\"cuda_rng_state_all\\\"] = torch.cuda.get_rng_state_all()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    save_full_checkpoint(last_checkpoint, LAST_CHECKPOINT_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if epochs_without_improvement >= EARLY_STOPPING_PATIENCE:\\n\",\n",
    "    \"        print(f\\\"Early stopping triggered after epoch {epoch}\\\")\\n\",\n",
    "    \"        break\\n\",\n",
    "    \"\\n\",\n",
    "    \"total_time = time.time() - start_time\\n\",\n",
    "    \"print(f\\\"\\\\nTraining finished in {total_time/60:.2f} minutes\\\")\\n\",\n",
    "    \"print(f\\\"Best epoch: {best_epoch}\\\")\\n\",\n",
    "    \"print(f\\\"Best val macro F1: {best_macro_f1:.6f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"if BEST_CHECKPOINT_LOCAL.exists():\\n\",\n",
    "    \"    best_loaded = torch.load(BEST_CHECKPOINT_LOCAL, map_location=device, weights_only=False)\\n\",\n",
    "    \"elif BEST_CHECKPOINT_LOCAL.exists():\\n\",\n",
    "    \"    best_loaded = torch.load(BEST_CHECKPOINT_LOCAL, map_location=device, weights_only=False)\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    best_loaded = torch.load(LAST_CHECKPOINT_LOCAL, map_location=device, weights_only=False)\\n\",\n",
    "    \"\\n\",\n",
