    "   \"source\": [\n",
    "    \"import json\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"from torch.utils.data import Dataset, DataLoader\\n\",\n",
    "    \"from torchvision import transforms\\n\",\n",
    "    \"import timm\\n\",\n",
    "    \"from timm.data import resolve_model_data_config, create_transform\\n\",\n",
    "    \"from sklearn.metrics import accuracy_score, f1_score, classification_report, confusion_matrix\\n\",\n",
    "    \"from tqdm import tqdm\\n\",\n",
    "    \"\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"device = torch.device(\\\"mps\\\" if torch.backends.mps.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"if torch.backends.mps.is_available():\\n\",\n",
    "    \"    torch.mps.empty_cache()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Using device:\\\", device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOCAL_RUN_NAME = \\\"model_i13_dinov2_train_aug_frozen\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"OUTPUT_DIR_BASE = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"MODEL_DIR_BASE = BASE_DIR / \\\"data\\\" / \\\"models\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"MODEL_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"DINO_MODEL_NAME = \\\"vit_small_patch14_dinov2\\\"\\n\",\n",
    "    \"BATCH_SIZE = 8\\n\",\n",
    "    \"IMAGE_SIZE = 224\\n\",\n",
    "    \"INITIAL_LR = 1e-4\\n\",\n",
    "    \"MAX_EPOCHS = 3\\n\",\n",
    "    \"EARLY_STOPPING_PATIENCE = 2\\n\",\n",
    "    \"WEIGHT_DECAY = 1e-4\\n\",\n",
    "    \"ACCUM_STEPS = 1\\n\",\n",
    "    \"NUM_WORKERS = 0\\n\",\n",
    "    \"MODEL_NAME = \\\"model_i13_dinov2_train_aug_frozen\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"TRAIN_SPLIT_PATH = SPLIT_DIR / \\\"train_split.csv\\\"\\n\",\n",
    "    \"VAL_SPLIT_PATH = SPLIT_DIR / \\\"val_split.csv\\\"\\n\",\n",
    "    \"LABEL2ID_PATH = SPLIT_DIR / \\\"label2id.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BEST_CHECKPOINT = MODEL_DIR_BASE / \\\"best_model_dinov2_small.pt\\\"\\n\",\n",
    "    \"LAST_CHECKPOINT = MODEL_DIR_BASE / \\\"last_checkpoint_dinov2_small.pt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"HISTORY_CSV = OUTPUT_DIR_BASE / \\\"history.csv\\\"\\n\",\n",
    "    \"VAL_PRED_CSV = OUTPUT_DIR_BASE / \\\"val_predictions.csv\\\"\\n\",\n",
    "    \"FUSION_TABLE_CSV = OUTPUT_DIR_BASE / \\\"val_fusion_table.csv\\\"\\n\",\n",
    "    \"CLASSIFICATION_REPORT_CSV = OUTPUT_DIR_BASE / \\\"classification_report.csv\\\"\\n\",\n",
    "    \"RUN_METADATA_JSON = OUTPUT_DIR_BASE / \\\"run_metadata.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOGITS_NPY = OUTPUT_DIR_BASE / \\\"y_logits.npy\\\"\\n\",\n",
    "    \"PROBA_NPY = OUTPUT_DIR_BASE / \\\"y_proba.npy\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"CONFUSION_MATRIX_PNG = OUTPUT_DIR_BASE / \\\"confusion_matrix.png\\\"\\n\",\n",
    "    \"TRAIN_LOSS_PNG = OUTPUT_DIR_BASE / \\\"train_loss.png\\\"\\n\",\n",
    "    \"TRAIN_ACC_PNG = OUTPUT_DIR_BASE / \\\"training_accuracy.png\\\"\\n\",\n",
    "    \"TRAIN_F1_PNG = OUTPUT_DIR_BASE / \\\"training_macro_f1.png\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"BASE_DIR:\\\", BASE_DIR)\\n\",\n",
    "    \"print(\\\"TRAIN_SPLIT_PATH exists:\\\", TRAIN_SPLIT_PATH.exists())\\n\",\n",
    "    \"print(\\\"VAL_SPLIT_PATH exists:\\\", VAL_SPLIT_PATH.exists())\\n\",\n",
    "    \"print(\\\"LABEL2ID_PATH exists:\\\", LABEL2ID_PATH.exists())\\n\",\n",
    "    \"print(\\\"IMAGE_DIR exists:\\\", IMAGE_DIR.exists())\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_df = pd.read_csv(TRAIN_SPLIT_PATH)\\n\",\n",
    "    \"val_df = pd.read_csv(VAL_SPLIT_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(LABEL2ID_PATH, \\\"r\\\") as f:\\n\",\n",
    "    \"    raw_label2id = json.load(f)\\n\",\n",
    "    \"\\n\",\n",
    "    \"label2id = {int(k): int(v) for k, v in raw_label2id.items()}\\n\",\n",
    "    \"id2label = {v: k for k, v in label2id.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"class DinoV2ImageClassifier(nn.Module):\\n\",\n",
    "    \"    def __init__(self, model_name, num_classes, freeze_backbone=True):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"        self.backbone = timm.create_model(\\n\",\n",
    "    \"            model_name,\\n\",\n",
    "    \"            pretrained=True,\\n\",\n",
    "    \"            num_classes=0\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if freeze_backbone:\\n\",\n",
    "    \"            for p in self.backbone.parameters():\\n\",\n",
    "    \"                p.requires_grad = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with torch.no_grad():\\n\",\n",
    "    \"            dummy_size = self.backbone.default_cfg[\\\"input_size\\\"][-1]\\n\",\n",
    "    \"            dummy = torch.zeros(1, 3, dummy_size, dummy_size)\\n\",\n",
    "    \"            feats = self.backbone.forward_features(dummy)\\n\",\n",
    "    \"            feats = self.backbone.forward_head(feats, pre_logits=True)\\n\",\n",
    "    \"            in_features = feats.shape[-1]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.classifier = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(in_features, 512),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Dropout(0.3),\\n\",\n",
    "    \"            nn.Linear(512, num_classes)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, image):\\n\",\n",
    "    \"        feats = self.backbone.forward_features(image)\\n\",\n",
    "    \"        feats = self.backbone.forward_head(feats, pre_logits=True)\\n\",\n",
    "    \"        logits = self.classifier(feats)\\n\",\n",
    "    \"        return logits\\n\",\n",
    "    \"\\n\",\n",
    "    \"model = DinoV2ImageClassifier(\\n\",\n",
    "    \"    model_name=DINO_MODEL_NAME,\\n\",\n",
    "    \"    num_classes=len(label2id),\\n\",\n",
    "    \"    freeze_backbone=True\\n\",\n",
    "    \").to(device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"data_cfg = resolve_model_data_config(model.backbone)\\n\",\n",
    "    \"print(\\\"Resolved model data config:\\\", data_cfg)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_transform = create_transform(\\n\",\n",
    "    \"    input_size=data_cfg[\\\"input_size\\\"],\\n\",\n",
    "    \"    mean=data_cfg[\\\"mean\\\"],\\n\",\n",
    "    \"    std=data_cfg[\\\"std\\\"],\\n\",\n",
    "    \"    interpolation=data_cfg[\\\"interpolation\\\"],\\n\",\n",
    "    \"    crop_pct=data_cfg.get(\\\"crop_pct\\\", 1.0),\\n\",\n",
    "    \"    is_training=True\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_transform = create_transform(\\n\",\n",
    "    \"    input_size=data_cfg[\\\"input_size\\\"],\\n\",\n",
    "    \"    mean=data_cfg[\\\"mean\\\"],\\n\",\n",
    "    \"    std=data_cfg[\\\"std\\\"],\\n\",\n",
    "    \"    interpolation=data_cfg[\\\"interpolation\\\"],\\n\",\n",
    "    \"    crop_pct=data_cfg.get(\\\"crop_pct\\\", 1.0),\\n\",\n",
    "    \"    is_training=False\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"class RakutenDinoDataset(torch.utils.data.Dataset):\\n\",\n",
    "    \"    def __init__(self, df, image_dir, label_mapping, transform):\\n\",\n",
    "    \"        self.df = df.reset_index(drop=True)\\n\",\n",
    "    \"        self.image_dir = image_dir\\n\",\n",
    "    \"        self.label_mapping = label_mapping\\n\",\n",
    "    \"        self.transform = transform\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __len__(self):\\n\",\n",
    "    \"        return len(self.df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __getitem__(self, idx):\\n\",\n",
    "    \"        row = self.df.iloc[idx]\\n\",\n",
    "    \"        img_path = self.image_dir / f\\\"image_{row['imageid']}_product_{row['productid']}.jpg\\\"\\n\",\n",
    "    \"        image = Image.open(img_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"        image = self.transform(image)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        label_id = self.label_mapping[int(row[\\\"prdtypecode\\\"])]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            \\\"image\\\": image,\\n\",\n",
    "    \"            \\\"labels\\\": torch.tensor(label_id, dtype=torch.long),\\n\",\n",
    "    \"            \\\"imageid\\\": row[\\\"imageid\\\"],\\n\",\n",
    "    \"            \\\"productid\\\": row[\\\"productid\\\"],\\n\",\n",
    "    \"            \\\"prdtypecode_raw\\\": int(row[\\\"prdtypecode\\\"])\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"def collate_fn(batch):\\n\",\n",
    "    \"    return {\\n\",\n",
    "    \"        \\\"image\\\": torch.stack([x[\\\"image\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"labels\\\": torch.stack([x[\\\"labels\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"imageid\\\": [x[\\\"imageid\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"productid\\\": [x[\\\"productid\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"prdtypecode_raw\\\": [x[\\\"prdtypecode_raw\\\"] for x in batch]\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_dataset = RakutenDinoDataset(train_df, IMAGE_DIR, label2id, train_transform)\\n\",\n",
    "    \"val_dataset = RakutenDinoDataset(val_df, IMAGE_DIR, label2id, val_transform)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_loader = DataLoader(\\n\",\n",
    "    \"    train_dataset,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=True,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=False,\\n\",\n",
    "    \"    collate_fn=collate_fn\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_loader = DataLoader(\\n\",\n",
    "    \"    val_dataset,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=False,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=False,\\n\",\n",
    "    \"    collate_fn=collate_fn\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"optimizer = torch.optim.AdamW(\\n\",\n",
    "    \"    [p for p in model.parameters() if p.requires_grad],\\n\",\n",
    "    \"    lr=INITIAL_LR,\\n\",\n",
    "    \"    weight_decay=WEIGHT_DECAY\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"criterion = nn.CrossEntropyLoss()\\n\",\n",
    "    \"scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\\n\",\n",
    "    \"    optimizer,\\n\",\n",
    "    \"    mode=\\\"max\\\",\\n\",\n",
    "    \"    factor=0.5,\\n\",\n",
    "    \"    patience=1\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"def plot_history(history_df):\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_loss\\\"], label=\\\"Train Loss\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_loss\\\"], label=\\\"Val Loss\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Loss\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Loss\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(TRAIN_LOSS_PNG, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_acc\\\"], label=\\\"Train Accuracy\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_acc\\\"], label=\\\"Val Accuracy\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Accuracy\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Accuracy\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(TRAIN_ACC_PNG, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_f1\\\"], label=\\\"Train Macro F1\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_f1\\\"], label=\\\"Val Macro F1\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Macro F1\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Macro F1\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(TRAIN_F1_PNG, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def run_one_epoch(model, loader, criterion, optimizer=None, accum_steps=1, phase=\\\"train\\\"):\\n\",\n",
    "    \"    train_mode = optimizer is not None\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if train_mode:\\n\",\n",
    "    \"        model.train()\\n\",\n",
    "    \"        optimizer.zero_grad()\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    running_loss = 0.0\\n\",\n",
    "    \"    all_preds = []\\n\",\n",
    "    \"    all_true = []\\n\",\n",
    "    \"    val_rows = []\\n\",\n",
    "    \"    all_logits = []\\n\",\n",
    "    \"    all_proba = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for step, batch in enumerate(tqdm(loader, desc=phase, leave=False), start=1):\\n\",\n",
    "    \"        images = batch[\\\"image\\\"].to(device)\\n\",\n",
    "    \"        labels = batch[\\\"labels\\\"].to(device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with torch.set_grad_enabled(train_mode):\\n\",\n",
    "    \"            logits = model(images)\\n\",\n",
    "    \"            loss = criterion(logits, labels)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if train_mode:\\n\",\n",
    "    \"                (loss / accum_steps).backward()\\n\",\n",
    "    \"                if step % accum_steps == 0 or step == len(loader):\\n\",\n",
    "    \"                    optimizer.step()\\n\",\n",
    "    \"                    optimizer.zero_grad()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        running_loss += loss.item() * labels.size(0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        probs = torch.softmax(logits, dim=1)\\n\",\n",
    "    \"        preds = torch.argmax(logits, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        all_preds.extend(preds.detach().cpu().numpy())\\n\",\n",
    "    \"        all_true.extend(labels.detach().cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if not train_mode:\\n\",\n",
    "    \"            batch_logits = logits.detach().cpu().numpy()\\n\",\n",
    "    \"            batch_proba = probs.detach().cpu().numpy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            all_logits.append(batch_logits)\\n\",\n",
    "    \"            all_proba.append(batch_proba)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            for j in range(labels.size(0)):\\n\",\n",
    "    \"                pred_label_id = int(preds[j].detach().cpu().item())\\n\",\n",
    "    \"                true_label_id = int(labels[j].detach().cpu().item())\\n\",\n",
    "    \"\\n\",\n",
    "    \"                row_dict = {\\n\",\n",
    "    \"                    \\\"imageid\\\": batch[\\\"imageid\\\"][j],\\n\",\n",
    "    \"                    \\\"productid\\\": batch[\\\"productid\\\"][j],\\n\",\n",
    "    \"                    \\\"true_label_id\\\": true_label_id,\\n\",\n",
    "    \"                    \\\"pred_label_id\\\": pred_label_id,\\n\",\n",
    "    \"                    \\\"true_prdtypecode\\\": int(id2label[true_label_id]),\\n\",\n",
    "    \"                    \\\"pred_prdtypecode\\\": int(id2label[pred_label_id]),\\n\",\n",
    "    \"                    \\\"confidence\\\": float(batch_proba[j].max())\\n\",\n",
    "    \"                }\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for c in range(batch_logits.shape[1]):\\n\",\n",
    "    \"                    row_dict[f\\\"logit_{c}\\\"] = float(batch_logits[j, c])\\n\",\n",
    "    \"                    row_dict[f\\\"proba_{c}\\\"] = float(batch_proba[j, c])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                val_rows.append(row_dict)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    epoch_loss = running_loss / len(loader.dataset)\\n\",\n",
    "    \"    epoch_acc = accuracy_score(all_true, all_preds)\\n\",\n",
    "    \"    epoch_f1 = f1_score(all_true, all_preds, average=\\\"macro\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if not train_mode:\\n\",\n",
    "    \"        all_logits = np.concatenate(all_logits, axis=0)\\n\",\n",
    "    \"        all_proba = np.concatenate(all_proba, axis=0)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        all_logits = None\\n\",\n",
    "    \"        all_proba = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return epoch_loss, epoch_acc, epoch_f1, all_true, all_preds, val_rows, all_logits, all_proba\\n\",\n",
    "    \"\\n\",\n",
    "    \"start_epoch = 1\\n\",\n",
    "    \"history = []\\n\",\n",
    "    \"best_f1 = -1.0\\n\",\n",
    "    \"epochs_without_improvement = 0\\n\",\n",
    "    \"resume_path = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"if BEST_CHECKPOINT.exists():\\n\",\n",
    "    \"    resume_path = BEST_CHECKPOINT\\n\",\n",
    "    \"elif LAST_CHECKPOINT.exists():\\n\",\n",
    "    \"    resume_path = LAST_CHECKPOINT\\n\",\n",
    "    \"\\n\",\n",
    "    \"if resume_path is not None:\\n\",\n",
