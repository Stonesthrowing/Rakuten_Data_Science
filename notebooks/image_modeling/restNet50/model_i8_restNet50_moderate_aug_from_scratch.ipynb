    "    \"        \\\"lr\\\": current_lr\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(\\n\",\n",
    "    \"        f\\\"Epoch {epoch:02d}/{MAX_EPOCHS} | \\\"\\n\",\n",
    "    \"        f\\\"train_loss={train_loss:.4f} | val_loss={val_loss:.4f} | \\\"\\n\",\n",
    "    \"        f\\\"train_acc={train_acc:.4f} | val_acc={val_acc:.4f} | \\\"\\n\",\n",
