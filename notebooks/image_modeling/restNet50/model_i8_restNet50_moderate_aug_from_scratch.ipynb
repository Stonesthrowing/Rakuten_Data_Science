    "    \"        y_pred=y_pred_val,\\n\",\n",
    "    \"        y_proba=y_proba_val\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    copy_to_local(LAST_CKPT_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Save best checkpoint if improved\\n\",\n",
    "    \"    if val_macro_f1 > best_macro_f1:\\n\",\n",
    "    \"        best_macro_f1 = val_macro_f1\\n\",\n",
    "    \"        best_epoch = epoch\\n\",\n",
    "    \"        epochs_without_improvement = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        save_full_checkpoint(\\n\",\n",
    "    \"            checkpoint_path=BEST_CKPT_LOCAL,\\n\",\n",
    "    \"            epoch=epoch,\\n\",\n",
    "    \"            model=model_G,\\n\",\n",
    "    \"            optimizer=optimizer,\\n\",\n",
    "    \"            scheduler=scheduler,\\n\",\n",
    "    \"            history=history,\\n\",\n",
    "    \"            best_macro_f1=best_macro_f1,\\n\",\n",
    "    \"            best_epoch=best_epoch,\\n\",\n",
    "    \"            model_name=MODEL_NAME,\\n\",\n",
    "    \"            y_true=y_true_val,\\n\",\n",
    "    \"            y_pred=y_pred_val,\\n\",\n",
    "    \"            y_proba=y_proba_val\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        copy_to_local(BEST_CKPT_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        torch.save(model_G.state_dict(), BEST_WEIGHTS_LOCAL)\\n\",\n",
    "    \"        copy_to_local(BEST_WEIGHTS_LOCAL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"  -> New best model saved at epoch {epoch} (val_macro_f1={val_macro_f1:.4f})\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        epochs_without_improvement += 1\\n\",\n",
    "    \"        print(f\\\"  -> No improvement for {epochs_without_improvement} epoch(s)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    elapsed_minutes = (time.time() - start_time) / 60\\n\",\n",
    "    \"    save_history_and_metadata(history, best_epoch, best_macro_f1, elapsed_minutes)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if epochs_without_improvement >= EARLY_STOPPING_PATIENCE:\\n\",\n",
    "    \"        print(f\\\"Early stopping triggered after epoch {epoch}\\\")\\n\",\n",
    "    \"        break\\n\",\n",
    "    \"\\n\",\n",
    "    \"total_time = time.time() - start_time\\n\",\n",
    "    \"print(f\\\"\\\\nTraining finished in {total_time/60:.2f} minutes\\\")\\n\",\n",
    "    \"print(f\\\"Best epoch: {best_epoch}\\\")\\n\",\n",
    "    \"print(f\\\"Best val macro F1: {best_macro_f1:.6f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Load best model weights\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"model_G.load_state_dict(torch.load(BEST_WEIGHTS_LOCAL, map_location=device))\\n\",\n",
