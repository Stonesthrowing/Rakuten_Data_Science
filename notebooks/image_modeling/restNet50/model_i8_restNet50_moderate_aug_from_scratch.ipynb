    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_macro_f1\\\"], label=\\\"Val Macro F1\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
