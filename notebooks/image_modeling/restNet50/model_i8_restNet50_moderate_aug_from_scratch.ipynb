    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# @title Model G - ResNet50 scratch\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"# MODEL G\\n\",\n",
    "    \"# ResNet50 from scratch - 224x224\\n\",\n",
    "    \"# WITH augmentation\\n\",\n",
    "    \"# FULL STATE CHECKPOINTING (local )\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Clean memory before starting\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"import gc\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"import shutil\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"from torch.utils.data import Dataset, DataLoader\\n\",\n",
    "    \"from torchvision import transforms, models\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"from sklearn.metrics import (\\n\",\n",
    "    \"    accuracy_score,\\n\",\n",
    "    \"    f1_score,\\n\",\n",
    "    \"    classification_report,\\n\",\n",
    "    \"    confusion_matrix\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOCAL_RUN_NAME = \\\"model_i10_efficientNetB0_noaug_partial\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent\\n\",\n",
    "    \"LOCAL_DATA_DIR = BASE_DIR / \\\"data\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR_BASE = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"MODEL_DIR_BASE = BASE_DIR / \\\"data\\\" / \\\"models\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"FIGURE_DIR_BASE = BASE_DIR / \\\"figures\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"MODEL_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"FIGURE_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"train_df = pd.read_csv(SPLIT_DIR / \\\"train_split.csv\\\")\\n\",\n",
    "    \"val_df = pd.read_csv(SPLIT_DIR / \\\"val_split.csv\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(SPLIT_DIR / \\\"label2id.json\\\") as f:\\n\",\n",
    "    \"    label2id = {int(k): int(v) for k, v in json.load(f).items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Reproducibility\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"torch.cuda.manual_seed_all(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Device\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"device = torch.device(\\\"cuda\\\" if torch.cuda.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"print(\\\"Using device:\\\", device)\\n\",\n",
    "    \"if torch.cuda.is_available():\\n\",\n",
    "    \"    print(\\\"GPU:\\\", torch.cuda.get_device_name(0))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Run folders\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# LOCAL_RUN_NAME = \\\"resnet50_scratch_224_aug\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOCAL_RUN_NAME = \\\"model_i8_restNet50_moderate_aug_from_scratch\\\"\\n\",\n",
    "    \"LOCAL_OUTPUT_ROOT = LOCAL_DATA_DIR / \\\"outputs\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"LOCAL_MODEL_ROOT = LOCAL_DATA_DIR / \\\"models\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"\\n\",\n",
    "    \"for d in [\\n\",\n",
    "    \"    LOCAL_OUTPUT_ROOT, LOCAL_MODEL_ROOT,\\n\",\n",
    "    \"]:\\n\",\n",
    "    \"    d.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Local output root:\\\", LOCAL_OUTPUT_ROOT)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Parameters\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"IMAGE_SIZE = 224\\n\",\n",
    "    \"BATCH_SIZE = 16\\n\",\n",
    "    \"NUM_WORKERS = 2\\n\",\n",
    "    \"MODEL_NAME = \\\"ResNet50_Scratch_224_Aug\\\"\\n\",\n",
    "    \"MAX_EPOCHS = 18\\n\",\n",
    "    \"EARLY_STOPPING_PATIENCE = 5\\n\",\n",
    "    \"\\n\",\n",
    "    \"RESUME_TRAINING = False\\n\",\n",
    "    \"CHECKPOINT_SOURCE = \\\"local_last\\\"   # local_last, local_best\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Transforms\\n\",\n",
    "    \"# Same augmentation pattern as Model C\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"train_transform_G = transforms.Compose([\\n\",\n",
    "    \"    transforms.Resize((IMAGE_SIZE + 20, IMAGE_SIZE + 20)),\\n\",\n",
    "    \"    transforms.RandomResizedCrop(IMAGE_SIZE, scale=(0.85, 1.0)),\\n\",\n",
    "    \"    transforms.RandomHorizontalFlip(),\\n\",\n",
    "    \"    transforms.RandomRotation(10),\\n\",\n",
    "    \"    transforms.ColorJitter(brightness=0.15, contrast=0.15, saturation=0.15),\\n\",\n",
    "    \"    transforms.ToTensor(),\\n\",\n",
    "    \"    transforms.Normalize(\\n\",\n",
    "    \"        mean=[0.485, 0.456, 0.406],\\n\",\n",
    "    \"        std=[0.229, 0.224, 0.225]\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_transform_G = transforms.Compose([\\n\",\n",
    "    \"    transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),\\n\",\n",
    "    \"    transforms.ToTensor(),\\n\",\n",
    "    \"    transforms.Normalize(\\n\",\n",
    "    \"        mean=[0.485, 0.456, 0.406],\\n\",\n",
    "    \"        std=[0.229, 0.224, 0.225]\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Dataset\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"class RakutenImageDataset(Dataset):\\n\",\n",
    "    \"    def __init__(self, df, transform=None, path_col=\\\"image_path_local\\\", label_col=\\\"label_id\\\"):\\n\",\n",
    "    \"        self.df = df.reset_index(drop=True)\\n\",\n",
    "    \"        self.transform = transform\\n\",\n",
    "    \"        self.path_col = path_col\\n\",\n",
    "    \"        self.label_col = label_col\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __len__(self):\\n\",\n",
    "    \"        return len(self.df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __getitem__(self, idx):\\n\",\n",
    "    \"        img_path = self.df.loc[idx, self.path_col]\\n\",\n",
    "    \"        label = int(self.df.loc[idx, self.label_col])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        image = Image.open(img_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"        if self.transform is not None:\\n\",\n",
    "    \"            image = self.transform(image)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return image, label\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_dataset_G = RakutenImageDataset(train_df, transform=train_transform_G)\\n\",\n",
    "    \"val_dataset_G = RakutenImageDataset(val_df, transform=val_transform_G)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_loader_G = DataLoader(\\n\",\n",
    "    \"    train_dataset_G,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=True,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=torch.cuda.is_available()\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_loader_G = DataLoader(\\n\",\n",
    "    \"    val_dataset_G,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=False,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=torch.cuda.is_available()\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Model: ResNet50 from scratch\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"model_G = models.resnet50(weights=None)\\n\",\n",
    "    \"in_features = model_G.fc.in_features\\n\",\n",
    "    \"model_G.fc = nn.Sequential(\\n\",\n",
    "    \"    nn.Dropout(0.3),\\n\",\n",
    "    \"    nn.Linear(in_features, len(label2id))\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"model_G = model_G.to(device)\\n\",\n",
    "    \"print(model_G)\\n\",\n",
    "    \"\\n\",\n",
    "    \"trainable_params = sum(p.numel() for p in model_G.parameters() if p.requires_grad)\\n\",\n",
    "    \"all_params = sum(p.numel() for p in model_G.parameters())\\n\",\n",
    "    \"print(f\\\"Trainable params: {trainable_params:,}\\\")\\n\",\n",
    "    \"print(f\\\"Total params    : {all_params:,}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Loss, optimizer, scheduler\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"criterion = nn.CrossEntropyLoss()\\n\",\n",
    "    \"\\n\",\n",
    "    \"optimizer = torch.optim.AdamW(\\n\",\n",
    "    \"    model_G.parameters(),\\n\",\n",
    "    \"    lr=3e-4,\\n\",\n",
    "    \"    weight_decay=1e-4\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\\n\",\n",
    "    \"    optimizer,\\n\",\n",
    "    \"    mode=\\\"max\\\",\\n\",\n",
    "    \"    factor=0.5,\\n\",\n",
    "    \"    patience=2,\\n\",\n",
    "    \"    min_lr=1e-6\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Checkpoint paths\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"LAST_CKPT_LOCAL = LOCAL_MODEL_ROOT / \\\"last_checkpoint.pt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BEST_CKPT_LOCAL = LOCAL_MODEL_ROOT / \\\"best_checkpoint.pt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BEST_WEIGHTS_LOCAL = LOCAL_MODEL_ROOT / \\\"best_model_state_dict.pt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Helper functions\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"def copy_to_local(local_path):\\n\",\n",
    "    \"    shutil.copy2(local_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def save_full_checkpoint(\\n\",\n",
    "    \"    checkpoint_path,\\n\",\n",
    "    \"    epoch,\\n\",\n",
    "    \"    model,\\n\",\n",
    "    \"    optimizer,\\n\",\n",
    "    \"    scheduler,\\n\",\n",
    "    \"    history,\\n\",\n",
    "    \"    best_macro_f1,\\n\",\n",
    "    \"    best_epoch,\\n\",\n",
    "    \"    model_name,\\n\",\n",
    "    \"    y_true=None,\\n\",\n",
    "    \"    y_pred=None,\\n\",\n",
    "    \"    y_proba=None\\n\",\n",
    "    \"):\\n\",\n",
    "    \"    checkpoint = {\\n\",\n",
    "    \"        \\\"epoch\\\": epoch,\\n\",\n",
    "    \"        \\\"model_state_dict\\\": model.state_dict(),\\n\",\n",
    "    \"        \\\"optimizer_state_dict\\\": optimizer.state_dict(),\\n\",\n",
    "    \"        \\\"scheduler_state_dict\\\": scheduler.state_dict(),\\n\",\n",
    "    \"        \\\"history\\\": history,\\n\",\n",
    "    \"        \\\"best_macro_f1\\\": best_macro_f1,\\n\",\n",
    "    \"        \\\"best_epoch\\\": best_epoch,\\n\",\n",
    "    \"        \\\"model_name\\\": model_name,\\n\",\n",
    "    \"        \\\"torch_rng_state\\\": torch.get_rng_state(),\\n\",\n",
    "    \"        \\\"numpy_rng_state\\\": np.random.get_state(),\\n\",\n",
    "    \"        \\\"python_rng_state\\\": random.getstate(),\\n\",\n",
    "    \"        \\\"y_true_last_val\\\": y_true,\\n\",\n",
    "    \"        \\\"y_pred_last_val\\\": y_pred,\\n\",\n",
    "    \"        \\\"y_proba_last_val\\\": y_proba,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if torch.cuda.is_available():\\n\",\n",
    "    \"        checkpoint[\\\"cuda_rng_state_all\\\"] = torch.cuda.get_rng_state_all()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    torch.save(checkpoint, checkpoint_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_full_checkpoint(checkpoint_path, model, optimizer, scheduler, device):\\n\",\n",
    "    \"    checkpoint = torch.load(checkpoint_path, map_location=device, weights_only=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    model.load_state_dict(checkpoint[\\\"model_state_dict\\\"])\\n\",\n",
    "    \"    optimizer.load_state_dict(checkpoint[\\\"optimizer_state_dict\\\"])\\n\",\n",
    "    \"    scheduler.load_state_dict(checkpoint[\\\"scheduler_state_dict\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if \\\"torch_rng_state\\\" in checkpoint:\\n\",\n",
    "    \"        torch.set_rng_state(checkpoint[\\\"torch_rng_state\\\"])\\n\",\n",
    "    \"    if \\\"numpy_rng_state\\\" in checkpoint:\\n\",\n",
    "    \"        np.random.set_state(checkpoint[\\\"numpy_rng_state\\\"])\\n\",\n",
    "    \"    if \\\"python_rng_state\\\" in checkpoint:\\n\",\n",
    "    \"        random.setstate(checkpoint[\\\"python_rng_state\\\"])\\n\",\n",
    "    \"    if torch.cuda.is_available() and \\\"cuda_rng_state_all\\\" in checkpoint:\\n\",\n",
    "    \"        torch.cuda.set_rng_state_all(checkpoint[\\\"cuda_rng_state_all\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    start_epoch = checkpoint[\\\"epoch\\\"] + 1\\n\",\n",
    "    \"    history = checkpoint.get(\\\"history\\\", [])\\n\",\n",
    "    \"    best_macro_f1 = checkpoint.get(\\\"best_macro_f1\\\", -np.inf)\\n\",\n",
    "    \"    best_epoch = checkpoint.get(\\\"best_epoch\\\", -1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Resumed from checkpoint: {checkpoint_path}\\\")\\n\",\n",
    "    \"    print(f\\\"Starting at epoch: {start_epoch}\\\")\\n\",\n",
    "    \"    print(f\\\"Best macro F1 so far: {best_macro_f1:.4f} at epoch {best_epoch}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return start_epoch, history, best_macro_f1, best_epoch\\n\",\n",
    "    \"\\n\",\n",
    "    \"def run_epoch(model, loader, criterion, optimizer=None):\\n\",\n",
    "    \"    is_train = optimizer is not None\\n\",\n",
    "    \"    model.train() if is_train else model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    running_loss = 0.0\\n\",\n",
    "    \"    all_preds = []\\n\",\n",
    "    \"    all_true = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for images, labels in loader:\\n\",\n",
    "    \"        images = images.to(device, non_blocking=True)\\n\",\n",
    "    \"        labels = labels.to(device, non_blocking=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if is_train:\\n\",\n",
    "    \"            optimizer.zero_grad()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with torch.set_grad_enabled(is_train):\\n\",\n",
    "    \"            logits = model(images)\\n\",\n",
    "    \"            loss = criterion(logits, labels)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if is_train:\\n\",\n",
    "    \"                loss.backward()\\n\",\n",
    "    \"                optimizer.step()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        running_loss += loss.item() * images.size(0)\\n\",\n",
    "    \"        preds = torch.argmax(logits, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        all_preds.extend(preds.detach().cpu().numpy())\\n\",\n",
    "    \"        all_true.extend(labels.detach().cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    epoch_loss = running_loss / len(loader.dataset)\\n\",\n",
    "    \"    epoch_acc = accuracy_score(all_true, all_preds)\\n\",\n",
    "    \"    epoch_macro_f1 = f1_score(all_true, all_preds, average=\\\"macro\\\")\\n\",\n",
    "    \"    epoch_weighted_f1 = f1_score(all_true, all_preds, average=\\\"weighted\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return epoch_loss, epoch_acc, epoch_macro_f1, epoch_weighted_f1, np.array(all_true), np.array(all_preds)\\n\",\n",
    "    \"\\n\",\n",
    "    \"def predict_with_proba(model, loader):\\n\",\n",
    "    \"    model.eval()\\n\",\n",
    "    \"    all_probs = []\\n\",\n",
    "    \"    all_preds = []\\n\",\n",
    "    \"    all_true = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    with torch.no_grad():\\n\",\n",
    "    \"        for images, labels in loader:\\n\",\n",
    "    \"            images = images.to(device, non_blocking=True)\\n\",\n",
    "    \"            labels = labels.to(device, non_blocking=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            logits = model(images)\\n\",\n",
    "    \"            probs = torch.softmax(logits, dim=1)\\n\",\n",
    "    \"            preds = torch.argmax(probs, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            all_probs.append(probs.cpu().numpy())\\n\",\n",
    "    \"            all_preds.append(preds.cpu().numpy())\\n\",\n",
    "    \"            all_true.append(labels.cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    y_proba = np.concatenate(all_probs)\\n\",\n",
    "    \"    y_pred = np.concatenate(all_preds)\\n\",\n",
    "    \"    y_true = np.concatenate(all_true)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return y_true, y_pred, y_proba\\n\",\n",
    "    \"\\n\",\n",
    "    \"def plot_history(history_df, save_dir_local):\\n\",\n",
    "    \"    # Loss\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_loss\\\"], label=\\\"Train Loss\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_loss\\\"], label=\\\"Val Loss\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Loss\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Loss\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    loss_local = save_dir_local / \\\"training_loss.png\\\"\\n\",\n",
    "    \"    plt.savefig(loss_local, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    shutil.copy2(loss_local)\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Accuracy\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_acc\\\"], label=\\\"Train Accuracy\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_acc\\\"], label=\\\"Val Accuracy\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Accuracy\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Accuracy\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
