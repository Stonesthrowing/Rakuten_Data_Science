    "    \"    plt.savefig(f1_local, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    shutil.copy2(f1_local)\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def save_history_and_metadata(history, best_epoch, best_macro_f1, total_minutes):\\n\",\n",
    "    \"    history_df = pd.DataFrame(history)\\n\",\n",
    "    \"    history_local = LOCAL_OUTPUT_ROOT / \\\"training_history.csv\\\"\\n\",\n",
    "    \"    history_df.to_csv(history_local, index=False)\\n\",\n",
    "    \"    copy_to_local(history_local)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    metadata = {\\n\",\n",
    "    \"        \\\"model_name\\\": MODEL_NAME,\\n\",\n",
    "    \"        \\\"image_size\\\": IMAGE_SIZE,\\n\",\n",
    "    \"        \\\"augmentation\\\": True,\\n\",\n",
    "    \"        \\\"architecture\\\": \\\"ResNet50_Scratch\\\",\\n\",\n",
    "    \"        \\\"unfrozen_blocks\\\": \\\"all\\\",\\n\",\n",
    "    \"        \\\"epochs_trained\\\": int(len(history)),\\n\",\n",
    "    \"        \\\"best_epoch\\\": int(best_epoch),\\n\",\n",
    "    \"        \\\"batch_size\\\": int(BATCH_SIZE),\\n\",\n",
    "    \"        \\\"optimizer\\\": \\\"AdamW\\\",\\n\",\n",
    "    \"        \\\"initial_lr\\\": 3e-4,\\n\",\n",
    "    \"        \\\"weight_decay\\\": 1e-4,\\n\",\n",
    "    \"        \\\"scheduler\\\": \\\"ReduceLROnPlateau\\\",\\n\",\n",
    "    \"        \\\"early_stopping_patience\\\": int(EARLY_STOPPING_PATIENCE),\\n\",\n",
    "    \"        \\\"best_macro_f1\\\": float(best_macro_f1),\\n\",\n",
    "    \"        \\\"training_minutes\\\": float(total_minutes),\\n\",\n",
    "    \"        \\\"trainable_parameters\\\": int(trainable_params),\\n\",\n",
    "    \"        \\\"total_parameters\\\": int(all_params)\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    meta_local = LOCAL_OUTPUT_ROOT / \\\"run_metadata.json\\\"\\n\",\n",
    "    \"    with open(meta_local, \\\"w\\\") as f:\\n\",\n",
    "    \"        json.dump(metadata, f, indent=2)\\n\",\n",
    "    \"    copy_to_local(meta_local)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Resume option\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"start_epoch = 1\\n\",\n",
    "    \"history = []\\n\",\n",
    "    \"best_macro_f1 = -np.inf\\n\",\n",
    "    \"best_epoch = -1\\n\",\n",
    "    \"epochs_without_improvement = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"if RESUME_TRAINING:\\n\",\n",
    "    \"    checkpoint_map = {\\n\",\n",
    "    \"        \\\"local_last\\\": LAST_CKPT_LOCAL,\\n\",\n",
    "    \"        \\\"local_best\\\": BEST_CKPT_LOCAL,\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"    checkpoint_path = checkpoint_map[CHECKPOINT_SOURCE]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if checkpoint_path.exists():\\n\",\n",
    "    \"        start_epoch, history, best_macro_f1, best_epoch = load_full_checkpoint(\\n\",\n",
    "    \"            checkpoint_path,\\n\",\n",
    "    \"            model_G,\\n\",\n",
    "    \"            optimizer,\\n\",\n",
    "    \"            scheduler,\\n\",\n",
    "    \"            device\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        epochs_without_improvement = max(0, start_epoch - best_epoch - 1)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(f\\\"Resume requested but checkpoint not found: {checkpoint_path}\\\")\\n\",\n",
    "    \"        print(\\\"Starting from scratch instead.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Train\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"start_time = time.time()\\n\",\n",
    "    \"\\n\",\n",
    "    \"for epoch in range(start_epoch, MAX_EPOCHS + 1):\\n\",\n",
    "    \"    train_loss, train_acc, train_macro_f1, train_weighted_f1, _, _ = run_epoch(\\n\",\n",
    "    \"        model_G, train_loader_G, criterion, optimizer=optimizer\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    val_loss, val_acc, val_macro_f1, val_weighted_f1, _, _ = run_epoch(\\n\",\n",
    "    \"        model_G, val_loader_G, criterion, optimizer=None\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    y_true_val, y_pred_val, y_proba_val = predict_with_proba(model_G, val_loader_G)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    scheduler.step(val_macro_f1)\\n\",\n",
    "    \"    current_lr = optimizer.param_groups[0][\\\"lr\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    history.append({\\n\",\n",
    "    \"        \\\"epoch\\\": epoch,\\n\",\n",
    "    \"        \\\"train_loss\\\": train_loss,\\n\",\n",
    "    \"        \\\"train_acc\\\": train_acc,\\n\",\n",
    "    \"        \\\"train_macro_f1\\\": train_macro_f1,\\n\",\n",
