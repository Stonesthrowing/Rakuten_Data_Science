    "    \"    \\\"training_minutes\\\": total_time / 60\\n\",\n",
    "    \"}])\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nFinal validation metrics:\\\")\\n\",\n",
    "    \"print(metrics_df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"# Save metrics/history\\n\",\n",
    "    \"# ------------------------------------------------------------\\n\",\n",
    "    \"history_df = pd.DataFrame(history)\\n\",\n",
