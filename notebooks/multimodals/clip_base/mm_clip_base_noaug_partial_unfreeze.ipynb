    "   \"execution_count\": null,\n",
    "   \"source\": [\n",
    "    \"import json\\n\",\n",
    "    \"import time\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"from torch.utils.data import Dataset, DataLoader\\n\",\n",
    "    \"from transformers import CLIPModel, CLIPProcessor\\n\",\n",
    "    \"from sklearn.metrics import accuracy_score, f1_score, classification_report, confusion_matrix\\n\",\n",
    "    \"from tqdm import tqdm\\n\",\n",
    "    \"\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"device = torch.device(\\\"mps\\\" if torch.backends.mps.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"if torch.backends.mps.is_available():\\n\",\n",
    "    \"    torch.mps.empty_cache()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Using device:\\\", device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOCAL_RUN_NAME = \\\"mm_clip_base_noaug_partial_unfreeze\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"OUTPUT_DIR_BASE = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"MODEL_DIR_BASE = BASE_DIR / \\\"data\\\" / \\\"models\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"FIGURE_DIR_BASE = BASE_DIR / \\\"figures\\\" / LOCAL_RUN_NAME\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"MODEL_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"FIGURE_DIR_BASE.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"CLIP_ID = \\\"openai/clip-vit-base-patch32\\\"\\n\",\n",
    "    \"BATCH_SIZE = 8\\n\",\n",
    "    \"BACKBONE_LR = 2e-6\\n\",\n",
    "    \"CLASSIFIER_LR = 1e-5\\n\",\n",
    "    \"MAX_EPOCHS = 20\\n\",\n",
    "    \"EARLY_STOPPING_PATIENCE = 3\\n\",\n",
    "    \"WEIGHT_DECAY = 1e-4\\n\",\n",
    "    \"ACCUM_STEPS = 2\\n\",\n",
    "    \"NUM_WORKERS = 0\\n\",\n",
    "    \"MAX_TEXT_LEN = 77\\n\",\n",
    "    \"UNFREEZE_LAST_N = 2\\n\",\n",
    "    \"MODEL_NAME = \\\"CLIP_Multimodal_M3_Partial_Unfreeze\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"TRAIN_SPLIT_PATH = SPLIT_DIR / \\\"train_split.csv\\\"\\n\",\n",
    "    \"VAL_SPLIT_PATH = SPLIT_DIR / \\\"val_split.csv\\\"\\n\",\n",
    "    \"LABEL2ID_PATH = SPLIT_DIR / \\\"label2id.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"FROZEN_BEST_CHECKPOINT = BASE_DIR / \\\"data\\\" / \\\"models\\\" / \\\"mm_clip_base_noaug_frozen\\\" / \\\"best_model_clip.pt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"BEST_CHECKPOINT = MODEL_DIR_BASE / \\\"best_model_clip_partial.pt\\\"\\n\",\n",
    "    \"LAST_CHECKPOINT = MODEL_DIR_BASE / \\\"last_checkpoint_clip_partial.pt\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"HISTORY_CSV = OUTPUT_DIR_BASE / \\\"history.csv\\\"\\n\",\n",
    "    \"VAL_PRED_CSV = OUTPUT_DIR_BASE / \\\"val_predictions.csv\\\"\\n\",\n",
    "    \"FUSION_TABLE_CSV = OUTPUT_DIR_BASE / \\\"val_fusion_table.csv\\\"\\n\",\n",
    "    \"CLASSIFICATION_REPORT_CSV = OUTPUT_DIR_BASE / \\\"classification_report.csv\\\"\\n\",\n",
    "    \"RUN_METADATA_JSON = OUTPUT_DIR_BASE / \\\"run_metadata.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"LOGITS_NPY = OUTPUT_DIR_BASE / \\\"y_logits.npy\\\"\\n\",\n",
    "    \"PROBA_NPY = OUTPUT_DIR_BASE / \\\"y_proba.npy\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"CONFUSION_MATRIX_PNG = FIGURE_DIR_BASE / \\\"confusion_matrix.png\\\"\\n\",\n",
    "    \"TRAIN_LOSS_PNG = FIGURE_DIR_BASE / \\\"train_loss.png\\\"\\n\",\n",
    "    \"TRAIN_ACC_PNG = FIGURE_DIR_BASE / \\\"training_accuracy.png\\\"\\n\",\n",
    "    \"TRAIN_F1_PNG = FIGURE_DIR_BASE / \\\"training_macro_f1.png\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Output root:\\\", OUTPUT_DIR_BASE)\\n\",\n",
    "    \"print(\\\"Model root:\\\", MODEL_DIR_BASE)\\n\",\n",
    "    \"print(\\\"Figure root:\\\", FIGURE_DIR_BASE)\\n\",\n",
    "    \"print(\\\"Frozen best checkpoint:\\\", FROZEN_BEST_CHECKPOINT)\\n\",\n",
    "    \"print(\\\"Partial best checkpoint:\\\", BEST_CHECKPOINT)\\n\",\n",
    "    \"print(\\\"Partial last checkpoint:\\\", LAST_CHECKPOINT)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_df = pd.read_csv(TRAIN_SPLIT_PATH)\\n\",\n",
    "    \"val_df = pd.read_csv(VAL_SPLIT_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(LABEL2ID_PATH, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"    raw_label2id = json.load(f)\\n\",\n",
    "    \"\\n\",\n",
    "    \"label2id = {int(k): int(v) for k, v in raw_label2id.items()}\\n\",\n",
    "    \"id2label = {v: k for k, v in label2id.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"processor = CLIPProcessor.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class RakutenCLIPDataset(Dataset):\\n\",\n",
    "    \"    def __init__(self, df, processor, label_mapping, image_dir, max_text_len=77):\\n\",\n",
    "    \"        self.df = df.reset_index(drop=True)\\n\",\n",
    "    \"        self.processor = processor\\n\",\n",
    "    \"        self.label_mapping = label_mapping\\n\",\n",
    "    \"        self.image_dir = image_dir\\n\",\n",
    "    \"        self.max_text_len = max_text_len\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __len__(self):\\n\",\n",
    "    \"        return len(self.df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __getitem__(self, idx):\\n\",\n",
    "    \"        row = self.df.iloc[idx]\\n\",\n",
    "    \"        img_path = self.image_dir / f\\\"image_{row['imageid']}_product_{row['productid']}.jpg\\\"\\n\",\n",
    "    \"        image = Image.open(img_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        designation = \\\"\\\" if pd.isna(row.get(\\\"designation\\\", \\\"\\\")) else str(row.get(\\\"designation\\\", \\\"\\\"))\\n\",\n",
    "    \"        description = \\\"\\\" if pd.isna(row.get(\\\"description\\\", \\\"\\\")) else str(row.get(\\\"description\\\", \\\"\\\"))\\n\",\n",
    "    \"        text = f\\\"{designation} {description}\\\".strip()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        enc = self.processor(\\n\",\n",
    "    \"            text=[text],\\n\",\n",
    "    \"            images=image,\\n\",\n",
    "    \"            return_tensors=\\\"pt\\\",\\n\",\n",
    "    \"            padding=\\\"max_length\\\",\\n\",\n",
    "    \"            truncation=True,\\n\",\n",
    "    \"            max_length=self.max_text_len\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        item = {k: v.squeeze(0) for k, v in enc.items()}\\n\",\n",
    "    \"        item[\\\"labels\\\"] = torch.tensor(self.label_mapping[int(row[\\\"prdtypecode\\\"])], dtype=torch.long)\\n\",\n",
    "    \"        item[\\\"imageid\\\"] = row[\\\"imageid\\\"]\\n\",\n",
    "    \"        item[\\\"productid\\\"] = row[\\\"productid\\\"]\\n\",\n",
    "    \"        item[\\\"prdtypecode_raw\\\"] = int(row[\\\"prdtypecode\\\"])\\n\",\n",
    "    \"        return item\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def collate_fn(batch):\\n\",\n",
    "    \"    return {\\n\",\n",
    "    \"        \\\"pixel_values\\\": torch.stack([x[\\\"pixel_values\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"input_ids\\\": torch.stack([x[\\\"input_ids\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"attention_mask\\\": torch.stack([x[\\\"attention_mask\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"labels\\\": torch.stack([x[\\\"labels\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"imageid\\\": [x[\\\"imageid\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"productid\\\": [x[\\\"productid\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"prdtypecode_raw\\\": [x[\\\"prdtypecode_raw\\\"] for x in batch]\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_dataset = RakutenCLIPDataset(train_df, processor, label2id, IMAGE_DIR, MAX_TEXT_LEN)\\n\",\n",
    "    \"val_dataset = RakutenCLIPDataset(val_df, processor, label2id, IMAGE_DIR, MAX_TEXT_LEN)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_loader = DataLoader(\\n\",\n",
    "    \"    train_dataset,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=True,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=False,\\n\",\n",
    "    \"    collate_fn=collate_fn\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_loader = DataLoader(\\n\",\n",
    "    \"    val_dataset,\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=False,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS,\\n\",\n",
    "    \"    pin_memory=False,\\n\",\n",
    "    \"    collate_fn=collate_fn\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class CLIPMultimodalClassifier(nn.Module):\\n\",\n",
    "    \"    def __init__(self, clip_id, num_classes, unfreeze_last_n=2):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"        self.clip = CLIPModel.from_pretrained(clip_id)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for p in self.clip.parameters():\\n\",\n",
    "    \"            p.requires_grad = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for p in self.clip.text_projection.parameters():\\n\",\n",
    "    \"            p.requires_grad = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for p in self.clip.visual_projection.parameters():\\n\",\n",
    "    \"            p.requires_grad = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for layer in self.clip.text_model.encoder.layers[-unfreeze_last_n:]:\\n\",\n",
    "    \"            for p in layer.parameters():\\n\",\n",
    "    \"                p.requires_grad = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for layer in self.clip.vision_model.encoder.layers[-unfreeze_last_n:]:\\n\",\n",
    "    \"            for p in layer.parameters():\\n\",\n",
    "    \"                p.requires_grad = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"        proj_dim = self.clip.config.projection_dim\\n\",\n",
    "    \"        self.classifier = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(proj_dim * 2, 512),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Dropout(0.3),\\n\",\n",
    "    \"            nn.Linear(512, num_classes)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, pixel_values, input_ids, attention_mask):\\n\",\n",
    "    \"        outputs = self.clip(\\n\",\n",
    "    \"            pixel_values=pixel_values,\\n\",\n",
    "    \"            input_ids=input_ids,\\n\",\n",
    "    \"            attention_mask=attention_mask,\\n\",\n",
    "    \"            return_dict=True\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        image_features = outputs.image_embeds\\n\",\n",
    "    \"        text_features = outputs.text_embeds\\n\",\n",
    "    \"\\n\",\n",
    "    \"        image_features = image_features / image_features.norm(dim=-1, keepdim=True).clamp(min=1e-12)\\n\",\n",
    "    \"        text_features = text_features / text_features.norm(dim=-1, keepdim=True).clamp(min=1e-12)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        combined = torch.cat([image_features, text_features], dim=1)\\n\",\n",
    "    \"        return self.classifier(combined)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"model = CLIPMultimodalClassifier(\\n\",\n",
    "    \"    clip_id=CLIP_ID,\\n\",\n",
    "    \"    num_classes=len(label2id),\\n\",\n",
    "    \"    unfreeze_last_n=UNFREEZE_LAST_N\\n\",\n",
    "    \").to(device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def split_params(model):\\n\",\n",
    "    \"    backbone_params = []\\n\",\n",
    "    \"    classifier_params = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for name, param in model.named_parameters():\\n\",\n",
    "    \"        if not param.requires_grad:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"        if name.startswith(\\\"classifier\\\"):\\n\",\n",
    "    \"            classifier_params.append(param)\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            backbone_params.append(param)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return backbone_params, classifier_params\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"backbone_params, classifier_params = split_params(model)\\n\",\n",
    "    \"\\n\",\n",
    "    \"optimizer = torch.optim.AdamW(\\n\",\n",
    "    \"    [\\n\",\n",
    "    \"        {\\\"params\\\": backbone_params, \\\"lr\\\": BACKBONE_LR},\\n\",\n",
    "    \"        {\\\"params\\\": classifier_params, \\\"lr\\\": CLASSIFIER_LR},\\n\",\n",
    "    \"    ],\\n\",\n",
    "    \"    weight_decay=WEIGHT_DECAY\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"criterion = nn.CrossEntropyLoss()\\n\",\n",
    "    \"\\n\",\n",
    "    \"scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\\n\",\n",
    "    \"    optimizer,\\n\",\n",
    "    \"    mode=\\\"max\\\",\\n\",\n",
    "    \"    factor=0.5,\\n\",\n",
    "    \"    patience=2\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def plot_history(history_df):\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_loss\\\"], label=\\\"Train Loss\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_loss\\\"], label=\\\"Val Loss\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Loss\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Loss\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(TRAIN_LOSS_PNG, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_acc\\\"], label=\\\"Train Accuracy\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_acc\\\"], label=\\\"Val Accuracy\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Accuracy\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Accuracy\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(TRAIN_ACC_PNG, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.figure(figsize=(8, 5))\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"train_f1\\\"], label=\\\"Train Macro F1\\\")\\n\",\n",
    "    \"    plt.plot(history_df[\\\"epoch\\\"], history_df[\\\"val_f1\\\"], label=\\\"Val Macro F1\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Macro F1\\\")\\n\",\n",
    "    \"    plt.title(f\\\"{MODEL_NAME} - Macro F1\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(TRAIN_F1_PNG, dpi=200, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def run_one_epoch(model, loader, criterion, optimizer=None, accum_steps=1, phase=\\\"train\\\"):\\n\",\n",
    "    \"    train_mode = optimizer is not None\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if train_mode:\\n\",\n",
    "    \"        model.train()\\n\",\n",
    "    \"        optimizer.zero_grad()\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    running_loss = 0.0\\n\",\n",
    "    \"    all_preds = []\\n\",\n",
    "    \"    all_true = []\\n\",\n",
    "    \"    val_rows = []\\n\",\n",
    "    \"    all_logits = []\\n\",\n",
    "    \"    all_proba = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for step, batch in enumerate(tqdm(loader, desc=phase, leave=False), start=1):\\n\",\n",
    "    \"        pixel_values = batch[\\\"pixel_values\\\"].to(device)\\n\",\n",
    "    \"        input_ids = batch[\\\"input_ids\\\"].to(device)\\n\",\n",
    "    \"        attention_mask = batch[\\\"attention_mask\\\"].to(device)\\n\",\n",
    "    \"        labels = batch[\\\"labels\\\"].to(device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with torch.set_grad_enabled(train_mode):\\n\",\n",
    "    \"            logits = model(\\n\",\n",
    "    \"                pixel_values=pixel_values,\\n\",\n",
    "    \"                input_ids=input_ids,\\n\",\n",
    "    \"                attention_mask=attention_mask\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"            loss = criterion(logits, labels)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if train_mode:\\n\",\n",
    "    \"                (loss / accum_steps).backward()\\n\",\n",
    "    \"\\n\",\n",
    "    \"                if step % accum_steps == 0 or step == len(loader):\\n\",\n",
    "    \"                    optimizer.step()\\n\",\n",
    "    \"                    optimizer.zero_grad()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        running_loss += loss.item() * labels.size(0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        probs = torch.softmax(logits, dim=1)\\n\",\n",
    "    \"        preds = torch.argmax(logits, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        all_preds.extend(preds.detach().cpu().numpy())\\n\",\n",
    "    \"        all_true.extend(labels.detach().cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if not train_mode:\\n\",\n",
    "    \"            batch_logits = logits.detach().cpu().numpy()\\n\",\n",
    "    \"            batch_proba = probs.detach().cpu().numpy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            all_logits.append(batch_logits)\\n\",\n",
    "    \"            all_proba.append(batch_proba)\\n\",\n",
    "    \"\\n\",\n",
