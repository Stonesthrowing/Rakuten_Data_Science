    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"from torch.utils.data import Dataset, DataLoader\\n\",\n",
    "    \"\\n\",\n",
    "    \"from transformers import CamembertModel, AutoTokenizer, CLIPVisionModel, CLIPProcessor\\n\",\n",
    "    \"from sklearn.metrics import accuracy_score, f1_score, classification_report\\n\",\n",
    "    \"from tqdm import tqdm\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# CONFIG\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"DEVICE = torch.device(\\\"mps\\\" if torch.backends.mps.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"BATCH_SIZE = 16\\n\",\n",
    "    \"MAX_TEXT_LEN = 128\\n\",\n",
    "    \"\\n\",\n",
    "    \"CAMEMBERT_ID = \\\"camembert-base\\\"\\n\",\n",
    "    \"CLIP_ID = \\\"openai/clip-vit-base-patch32\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# PATHS\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent.parent\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"OUTPUT_DIR = BASE_DIR / \\\"outputs\\\"\\n\",\n",
    "    \"OUTPUT_DIR.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"INTERPRET_DIR = BASE_DIR / \\\"outputs\\\" / \\\"gradCam\\\"\\n\",\n",
    "    \"INTERPRET_DIR.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"BEST_MODEL_PATH = OUTPUT_DIR / \\\"best_model.pt\\\"\\n\",\n",
    "    \"INTERPRET_CSV_PATH = INTERPRET_DIR / \\\"interpretation_results.csv\\\"\\n\",\n",
    "    \"TOP_TEXT_CSV_PATH = INTERPRET_DIR / \\\"top_text_weighted_samples.csv\\\"\\n\",\n",
    "    \"TOP_VISION_CSV_PATH = INTERPRET_DIR / \\\"top_vision_weighted_samples.csv\\\"\\n\",\n",
    "    \"SUMMARY_JSON_PATH = INTERPRET_DIR / \\\"interpretation_summary.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# LOAD DATA\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"val_df = pd.read_csv(SPLIT_DIR / \\\"val_split.csv\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(SPLIT_DIR / \\\"label2id.json\\\", \\\"r\\\") as f:\\n\",\n",
    "    \"    label2id = {int(k): int(v) for k, v in json.load(f).items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"id2label = {v: k for k, v in label2id.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# TOKENIZER / PROCESSOR\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"tokenizer = AutoTokenizer.from_pretrained(CAMEMBERT_ID)\\n\",\n",
    "    \"processor = CLIPProcessor.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# DATASET\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"class RakutenDataset(Dataset):\\n\",\n",
    "    \"    def __init__(self, df):\\n\",\n",
    "    \"        self.df = df.reset_index(drop=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __len__(self):\\n\",\n",
    "    \"        return len(self.df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __getitem__(self, idx):\\n\",\n",
    "    \"        row = self.df.iloc[idx]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        img_path = IMAGE_DIR / f\\\"image_{row['imageid']}_product_{row['productid']}.jpg\\\"\\n\",\n",
    "    \"        image = Image.open(img_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        designation = \\\"\\\" if pd.isna(row.get(\\\"designation\\\", \\\"\\\")) else str(row.get(\\\"designation\\\", \\\"\\\"))\\n\",\n",
    "    \"        description = \\\"\\\" if pd.isna(row.get(\\\"description\\\", \\\"\\\")) else str(row.get(\\\"description\\\", \\\"\\\"))\\n\",\n",
    "    \"        text = f\\\"{designation} {description}\\\".strip()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        txt = tokenizer(\\n\",\n",
    "    \"            text,\\n\",\n",
    "    \"            padding=\\\"max_length\\\",\\n\",\n",
    "    \"            truncation=True,\\n\",\n",
    "    \"            max_length=MAX_TEXT_LEN,\\n\",\n",
    "    \"            return_tensors=\\\"pt\\\"\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        img = processor(images=image, return_tensors=\\\"pt\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            \\\"input_ids\\\": txt[\\\"input_ids\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"attention_mask\\\": txt[\\\"attention_mask\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"pixel_values\\\": img[\\\"pixel_values\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"labels\\\": torch.tensor(label2id[int(row[\\\"prdtypecode\\\"])], dtype=torch.long),\\n\",\n",
    "    \"            \\\"imageid\\\": row[\\\"imageid\\\"],\\n\",\n",
    "    \"            \\\"productid\\\": row[\\\"productid\\\"],\\n\",\n",
    "    \"            \\\"prdtypecode_raw\\\": int(row[\\\"prdtypecode\\\"]),\\n\",\n",
    "    \"            \\\"designation\\\": designation,\\n\",\n",
    "    \"            \\\"description\\\": description,\\n\",\n",
    "    \"            \\\"raw_text\\\": text\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"def collate_fn(batch):\\n\",\n",
    "    \"    return {\\n\",\n",
    "    \"        \\\"input_ids\\\": torch.stack([x[\\\"input_ids\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"attention_mask\\\": torch.stack([x[\\\"attention_mask\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"pixel_values\\\": torch.stack([x[\\\"pixel_values\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"labels\\\": torch.stack([x[\\\"labels\\\"] for x in batch]),\\n\",\n",
    "    \"        \\\"imageid\\\": [x[\\\"imageid\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"productid\\\": [x[\\\"productid\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"prdtypecode_raw\\\": [x[\\\"prdtypecode_raw\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"designation\\\": [x[\\\"designation\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"description\\\": [x[\\\"description\\\"] for x in batch],\\n\",\n",
    "    \"        \\\"raw_text\\\": [x[\\\"raw_text\\\"] for x in batch]\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_loader = DataLoader(\\n\",\n",
    "    \"    RakutenDataset(val_df),\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=False,\\n\",\n",
    "    \"    collate_fn=collate_fn\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# MODEL\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"class FusionModel(nn.Module):\\n\",\n",
    "    \"    def __init__(self, num_classes):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.text = CamembertModel.from_pretrained(CAMEMBERT_ID)\\n\",\n",
    "    \"        self.vision = CLIPVisionModel.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.gate = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(1536, 512),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Linear(512, 768),\\n\",\n",
    "    \"            nn.Sigmoid()\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.classifier = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(2304, 512),\\n\",\n",
    "    \"            nn.BatchNorm1d(512),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Dropout(0.3),\\n\",\n",
    "    \"            nn.Linear(512, num_classes)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, i, a, p, return_interpret=False):\\n\",\n",
    "    \"        text_outputs = self.text(input_ids=i, attention_mask=a)\\n\",\n",
    "    \"        vision_outputs = self.vision(pixel_values=p)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if text_outputs.pooler_output is not None:\\n\",\n",
    "    \"            t = text_outputs.pooler_output\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            t = text_outputs.last_hidden_state[:, 0, :]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        v = vision_outputs.pooler_output\\n\",\n",
    "    \"\\n\",\n",
    "    \"        t = t / t.norm(dim=-1, keepdim=True).clamp(min=1e-12)\\n\",\n",
    "    \"        v = v / v.norm(dim=-1, keepdim=True).clamp(min=1e-12)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        fusion = torch.cat([t, v], dim=1)\\n\",\n",
    "    \"        g = self.gate(fusion)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        fused = g * v + (1.0 - g) * t\\n\",\n",
    "    \"        final = torch.cat([fused, t, v], dim=1)\\n\",\n",
    "    \"        logits = self.classifier(final)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if return_interpret:\\n\",\n",
    "    \"            return logits, t, v, g, fused\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return logits\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# LOAD BEST MODEL\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"model = FusionModel(num_classes=len(label2id)).to(DEVICE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if not BEST_MODEL_PATH.exists():\\n\",\n",
    "    \"    raise FileNotFoundError(f\\\"Best model not found: {BEST_MODEL_PATH}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"state_dict = torch.load(BEST_MODEL_PATH, map_location=DEVICE)\\n\",\n",
    "    \"model.load_state_dict(state_dict)\\n\",\n",
    "    \"model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Loaded best model from:\\\", BEST_MODEL_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# INTERPRETATION\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"all_rows = []\\n\",\n",
    "    \"all_true = []\\n\",\n",
    "    \"all_pred = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"with torch.no_grad():\\n\",\n",
    "    \"    for batch in tqdm(val_loader, desc=\\\"Interpreting\\\"):\\n\",\n",
    "    \"        i = batch[\\\"input_ids\\\"].to(DEVICE)\\n\",\n",
    "    \"        a = batch[\\\"attention_mask\\\"].to(DEVICE)\\n\",\n",
    "    \"        p = batch[\\\"pixel_values\\\"].to(DEVICE)\\n\",\n",
    "    \"        y = batch[\\\"labels\\\"].to(DEVICE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        logits, t, v, g, fused = model(i, a, p, return_interpret=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        probs = torch.softmax(logits, dim=1)\\n\",\n",
    "    \"        preds = torch.argmax(probs, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        all_true.extend(y.cpu().numpy())\\n\",\n",
    "    \"        all_pred.extend(preds.cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        gate_mean = g.mean(dim=1).cpu().numpy()\\n\",\n",
    "    \"        text_contribution = (1.0 - g).mean(dim=1).cpu().numpy()\\n\",\n",
    "    \"        vision_contribution = g.mean(dim=1).cpu().numpy()\\n\",\n",
    "    \"        confidence = probs.max(dim=1).values.cpu().numpy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for idx_in_batch in range(len(batch[\\\"imageid\\\"])):\\n\",\n",
    "    \"            true_label_id = int(y[idx_in_batch].cpu().item())\\n\",\n",
    "    \"            pred_label_id = int(preds[idx_in_batch].cpu().item())\\n\",\n",
    "    \"\\n\",\n",
    "    \"            row = {\\n\",\n",
    "    \"                \\\"imageid\\\": batch[\\\"imageid\\\"][idx_in_batch],\\n\",\n",
    "    \"                \\\"productid\\\": batch[\\\"productid\\\"][idx_in_batch],\\n\",\n",
    "    \"                \\\"true_label_id\\\": true_label_id,\\n\",\n",
    "    \"                \\\"pred_label_id\\\": pred_label_id,\\n\",\n",
    "    \"                \\\"true_prdtypecode\\\": int(id2label[true_label_id]),\\n\",\n",
    "    \"                \\\"pred_prdtypecode\\\": int(id2label[pred_label_id]),\\n\",\n",
    "    \"                \\\"correct\\\": int(true_label_id == pred_label_id),\\n\",\n",
    "    \"                \\\"confidence\\\": float(confidence[idx_in_batch]),\\n\",\n",
    "    \"                \\\"gate_mean\\\": float(gate_mean[idx_in_batch]),\\n\",\n",
    "    \"                \\\"text_contribution\\\": float(text_contribution[idx_in_batch]),\\n\",\n",
    "    \"                \\\"vision_contribution\\\": float(vision_contribution[idx_in_batch]),\\n\",\n",
    "    \"                \\\"designation\\\": batch[\\\"designation\\\"][idx_in_batch],\\n\",\n",
    "    \"                \\\"description\\\": batch[\\\"description\\\"][idx_in_batch],\\n\",\n",
    "    \"                \\\"raw_text\\\": batch[\\\"raw_text\\\"][idx_in_batch]\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"            all_rows.append(row)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# SAVE RESULTS\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"result_df = pd.DataFrame(all_rows)\\n\",\n",
    "    \"result_df.to_csv(INTERPRET_CSV_PATH, index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"top_text_df = result_df.sort_values(\\\"text_contribution\\\", ascending=False).head(50)\\n\",\n",
    "    \"top_text_df.to_csv(TOP_TEXT_CSV_PATH, index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"top_vision_df = result_df.sort_values(\\\"vision_contribution\\\", ascending=False).head(50)\\n\",\n",
    "    \"top_vision_df.to_csv(TOP_VISION_CSV_PATH, index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"acc = accuracy_score(all_true, all_pred)\\n\",\n",
    "    \"macro_f1 = f1_score(all_true, all_pred, average=\\\"macro\\\")\\n\",\n",
    "    \"report = classification_report(all_true, all_pred, output_dict=True, zero_division=0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"summary = {\\n\",\n",
    "    \"    \\\"num_samples\\\": int(len(result_df)),\\n\",\n",
    "    \"    \\\"accuracy\\\": float(acc),\\n\",\n",
    "    \"    \\\"macro_f1\\\": float(macro_f1),\\n\",\n",
    "    \"    \\\"mean_gate\\\": float(result_df[\\\"gate_mean\\\"].mean()),\\n\",\n",
    "    \"    \\\"mean_text_contribution\\\": float(result_df[\\\"text_contribution\\\"].mean()),\\n\",\n",
    "    \"    \\\"mean_vision_contribution\\\": float(result_df[\\\"vision_contribution\\\"].mean()),\\n\",\n",
    "    \"    \\\"mean_gate_correct\\\": float(result_df[result_df[\\\"correct\\\"] == 1][\\\"gate_mean\\\"].mean()) if (result_df[\\\"correct\\\"] == 1).any() else None,\\n\",\n",
    "    \"    \\\"mean_gate_wrong\\\": float(result_df[result_df[\\\"correct\\\"] == 0][\\\"gate_mean\\\"].mean()) if (result_df[\\\"correct\\\"] == 0).any() else None\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(SUMMARY_JSON_PATH, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"    json.dump(summary, f, indent=2, ensure_ascii=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# PRINT SUMMARY\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"print(\\\"\\\\nInterpretation finished.\\\")\\n\",\n",
    "    \"print(f\\\"Accuracy: {acc:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"Macro F1: {macro_f1:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"Mean gate value: {result_df['gate_mean'].mean():.4f}\\\")\\n\",\n",
    "    \"print(f\\\"Mean text contribution: {result_df['text_contribution'].mean():.4f}\\\")\\n\",\n",
    "    \"print(f\\\"Mean vision contribution: {result_df['vision_contribution'].mean():.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nMost text-driven samples:\\\")\\n\",\n",
