    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import json\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"import torch.nn.functional as F\\n\",\n",
    "    \"\\n\",\n",
    "    \"from transformers import CamembertModel, AutoTokenizer, CLIPVisionModel, CLIPProcessor\\n\",\n",
    "    \"\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"DEVICE = torch.device(\\\"mps\\\" if torch.backends.mps.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"CAMEMBERT_ID = \\\"camembert-base\\\"\\n\",\n",
    "    \"CLIP_ID = \\\"openai/clip-vit-base-patch32\\\"\\n\",\n",
    "    \"MAX_TEXT_LEN = 128\\n\",\n",
    "    \"\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent.parent\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"OUTPUT_DIR = BASE_DIR / \\\"outputs\\\"\\n\",\n",
    "    \"GRADCAM_DIR = OUTPUT_DIR / \\\"gradCam\\\"\\n\",\n",
    "    \"GRADCAM_DIR.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"BEST_MODEL_PATH = OUTPUT_DIR / \\\"best_model.pt\\\"\\n\",\n",
    "    \"VAL_SPLIT_PATH = SPLIT_DIR / \\\"val_split.csv\\\"\\n\",\n",
    "    \"LABEL2ID_PATH = SPLIT_DIR / \\\"label2id.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_df = pd.read_csv(VAL_SPLIT_PATH)\\n\",\n",
    "    \"SAMPLE_INDEX = random.randint(0, len(val_df) - 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(LABEL2ID_PATH, \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"    label2id = {int(k): int(v) for k, v in json.load(f).items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"id2label = {v: k for k, v in label2id.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"tokenizer = AutoTokenizer.from_pretrained(CAMEMBERT_ID)\\n\",\n",
    "    \"processor = CLIPProcessor.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"\\n\",\n",
    "    \"class FusionModel(nn.Module):\\n\",\n",
    "    \"    def __init__(self, num_classes):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"        self.text = CamembertModel.from_pretrained(CAMEMBERT_ID)\\n\",\n",
    "    \"        self.vision = CLIPVisionModel.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"        self.gate = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(1536, 512),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Linear(512, 768),\\n\",\n",
    "    \"            nn.Sigmoid()\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        self.classifier = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(2304, 512),\\n\",\n",
    "    \"            nn.BatchNorm1d(512),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Dropout(0.3),\\n\",\n",
    "    \"            nn.Linear(512, num_classes)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, input_ids, attention_mask, pixel_values, return_interpret=False):\\n\",\n",
    "    \"        text_outputs = self.text(input_ids=input_ids, attention_mask=attention_mask)\\n\",\n",
    "    \"        vision_outputs = self.vision(pixel_values=pixel_values)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        t = text_outputs.pooler_output\\n\",\n",
    "    \"        if t is None:\\n\",\n",
    "    \"            t = text_outputs.last_hidden_state[:, 0, :]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        v = vision_outputs.pooler_output\\n\",\n",
    "    \"\\n\",\n",
    "    \"        t = t / t.norm(dim=-1, keepdim=True).clamp(min=1e-12)\\n\",\n",
    "    \"        v = v / v.norm(dim=-1, keepdim=True).clamp(min=1e-12)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        fusion = torch.cat([t, v], dim=1)\\n\",\n",
    "    \"        g = self.gate(fusion)\\n\",\n",
    "    \"        fused = g * v + (1.0 - g) * t\\n\",\n",
    "    \"        final = torch.cat([fused, t, v], dim=1)\\n\",\n",
    "    \"        logits = self.classifier(final)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if return_interpret:\\n\",\n",
    "    \"            return logits, g, t, v, fused\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return logits\\n\",\n",
    "    \"\\n\",\n",
    "    \"class ViTGradCAM:\\n\",\n",
    "    \"    def __init__(self, model, target_module):\\n\",\n",
    "    \"        self.model = model\\n\",\n",
    "    \"        self.target_module = target_module\\n\",\n",
    "    \"        self.activations = None\\n\",\n",
    "    \"        self.gradients = None\\n\",\n",
    "    \"        self.forward_handle = target_module.register_forward_hook(self._forward_hook)\\n\",\n",
    "    \"        self.backward_handle = target_module.register_full_backward_hook(self._backward_hook)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _forward_hook(self, module, inputs, output):\\n\",\n",
    "    \"        if isinstance(output, tuple):\\n\",\n",
    "    \"            output = output[0]\\n\",\n",
    "    \"        self.activations = output\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def _backward_hook(self, module, grad_input, grad_output):\\n\",\n",
    "    \"        grad = grad_output[0]\\n\",\n",
    "    \"        if isinstance(grad, tuple):\\n\",\n",
    "    \"            grad = grad[0]\\n\",\n",
    "    \"        self.gradients = grad\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def remove(self):\\n\",\n",
    "    \"        self.forward_handle.remove()\\n\",\n",
    "    \"        self.backward_handle.remove()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def generate(self, input_ids, attention_mask, pixel_values, target_class=None):\\n\",\n",
    "    \"        self.model.zero_grad(set_to_none=True)\\n\",\n",
    "    \"        logits = self.model(input_ids, attention_mask, pixel_values)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if target_class is None:\\n\",\n",
    "    \"            target_class = logits.argmax(dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        score = logits.gather(1, target_class.view(-1, 1)).sum()\\n\",\n",
    "    \"        score.backward()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        acts = self.activations\\n\",\n",
    "    \"        grads = self.gradients\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if acts is None or grads is None:\\n\",\n",
    "    \"            raise RuntimeError(\\\"Grad-CAM hooks did not capture activations/gradients.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if acts.dim() != 3 or grads.dim() != 3:\\n\",\n",
    "    \"            raise RuntimeError(f\\\"Expected 3D tensors, got acts={acts.shape}, grads={grads.shape}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        acts = acts[:, 1:, :]\\n\",\n",
    "    \"        grads = grads[:, 1:, :]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        weights = grads.mean(dim=1, keepdim=True)\\n\",\n",
    "    \"        cam = torch.relu((acts * weights).sum(dim=-1))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        n_patches = cam.shape[1]\\n\",\n",
    "    \"        side = int(n_patches ** 0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if side * side != n_patches:\\n\",\n",
    "    \"            raise RuntimeError(f\\\"Patch count is not square: {n_patches}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        cam_patch = cam.reshape(-1, side, side)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        cam_up = cam_patch.unsqueeze(1)\\n\",\n",
    "    \"        cam_up = F.interpolate(\\n\",\n",
    "    \"            cam_up,\\n\",\n",
    "    \"            size=pixel_values.shape[-2:],\\n\",\n",
    "    \"            mode=\\\"bilinear\\\",\\n\",\n",
    "    \"            align_corners=False\\n\",\n",
    "    \"        ).squeeze(1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        cam_min = cam_up.amin(dim=(1, 2), keepdim=True)\\n\",\n",
    "    \"        cam_max = cam_up.amax(dim=(1, 2), keepdim=True)\\n\",\n",
    "    \"        cam_up = (cam_up - cam_min) / (cam_max - cam_min + 1e-8)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        cam_patch_min = cam_patch.amin(dim=(1, 2), keepdim=True)\\n\",\n",
    "    \"        cam_patch_max = cam_patch.amax(dim=(1, 2), keepdim=True)\\n\",\n",
    "    \"        cam_patch = (cam_patch - cam_patch_min) / (cam_patch_max - cam_patch_min + 1e-8)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return cam_patch.detach().cpu().numpy(), cam_up.detach().cpu().numpy(), logits.detach()\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_image_path(row):\\n\",\n",
    "    \"    return IMAGE_DIR / f\\\"image_{row['imageid']}_product_{row['productid']}.jpg\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_sample(row):\\n\",\n",
    "    \"    image_path = build_image_path(row)\\n\",\n",
    "    \"    image = Image.open(image_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    designation = \\\"\\\" if pd.isna(row.get(\\\"designation\\\", \\\"\\\")) else str(row.get(\\\"designation\\\", \\\"\\\"))\\n\",\n",
    "    \"    description = \\\"\\\" if pd.isna(row.get(\\\"description\\\", \\\"\\\")) else str(row.get(\\\"description\\\", \\\"\\\"))\\n\",\n",
    "    \"    text = f\\\"{designation} {description}\\\".strip()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    txt = tokenizer(\\n\",\n",
    "    \"        text,\\n\",\n",
    "    \"        padding=\\\"max_length\\\",\\n\",\n",
    "    \"        truncation=True,\\n\",\n",
    "    \"        max_length=MAX_TEXT_LEN,\\n\",\n",
    "    \"        return_tensors=\\\"pt\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    img = processor(images=image, return_tensors=\\\"pt\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return image, text, txt, img, image_path\\n\",\n",
    "    \"\\n\",\n",
    "    \"def overlay_heatmap_on_image(pil_image, cam_2d, alpha=0.65):\\n\",\n",
    "    \"    image = np.array(pil_image).astype(np.float32) / 255.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    cam_img = Image.fromarray((cam_2d * 255).astype(np.uint8))\\n\",\n",
    "    \"    cam_img = cam_img.resize((pil_image.width, pil_image.height), resample=Image.BILINEAR)\\n\",\n",
    "    \"    cam_resized = np.array(cam_img).astype(np.float32) / 255.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    heatmap = plt.get_cmap(\\\"jet\\\")(cam_resized)[..., :3]\\n\",\n",
    "    \"    overlay = (1.0 - alpha) * image + alpha * heatmap\\n\",\n",
    "    \"    overlay = np.clip(overlay, 0, 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return overlay\\n\",\n",
    "    \"\\n\",\n",
    "    \"model = FusionModel(num_classes=len(label2id)).to(DEVICE)\\n\",\n",
    "    \"state_dict = torch.load(BEST_MODEL_PATH, map_location=DEVICE)\\n\",\n",
    "    \"model.load_state_dict(state_dict)\\n\",\n",
    "    \"model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"target_layer = model.vision.vision_model.encoder.layers[-1].layer_norm1\\n\",\n",
    "    \"gradcam = ViTGradCAM(model, target_layer)\\n\",\n",
    "    \"\\n\",\n",
    "    \"row = val_df.iloc[SAMPLE_INDEX]\\n\",\n",
    "    \"pil_image, raw_text, txt, img, image_path = load_sample(row)\\n\",\n",
    "    \"\\n\",\n",
    "    \"input_ids = txt[\\\"input_ids\\\"].to(DEVICE)\\n\",\n",
    "    \"attention_mask = txt[\\\"attention_mask\\\"].to(DEVICE)\\n\",\n",
    "    \"pixel_values = img[\\\"pixel_values\\\"].to(DEVICE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"with torch.enable_grad():\\n\",\n",
    "    \"    logits, g, _, _, _ = model(\\n\",\n",
    "    \"        input_ids,\\n\",\n",
    "    \"        attention_mask,\\n\",\n",
    "    \"        pixel_values,\\n\",\n",
    "    \"        return_interpret=True\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    probs = torch.softmax(logits, dim=1)\\n\",\n",
    "    \"    pred_id = int(torch.argmax(probs, dim=1).item())\\n\",\n",
    "    \"    confidence = float(torch.max(probs).item())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    cam_patch, cam_up, _ = gradcam.generate(\\n\",\n",
    "    \"        input_ids=input_ids,\\n\",\n",
    "    \"        attention_mask=attention_mask,\\n\",\n",
    "    \"        pixel_values=pixel_values,\\n\",\n",
    "    \"        target_class=torch.tensor([pred_id], device=DEVICE)\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"cam_patch min:\\\", float(cam_patch[0].min()))\\n\",\n",
    "    \"print(\\\"cam_patch max:\\\", float(cam_patch[0].max()))\\n\",\n",
    "    \"print(\\\"cam_patch mean:\\\", float(cam_patch[0].mean()))\\n\",\n",
    "    \"print(\\\"cam_up min:\\\", float(cam_up[0].min()))\\n\",\n",
    "    \"print(\\\"cam_up max:\\\", float(cam_up[0].max()))\\n\",\n",
    "    \"print(\\\"cam_up mean:\\\", float(cam_up[0].mean()))\\n\",\n",
    "    \"\\n\",\n",
    "    \"gate_mean = float(g.mean().item())\\n\",\n",
    "    \"vision_contribution = gate_mean\\n\",\n",
    "    \"text_contribution = 1.0 - gate_mean\\n\",\n",
    "    \"\\n\",\n",
    "    \"pred_prdtypecode = id2label[pred_id]\\n\",\n",
    "    \"true_prdtypecode = int(row[\\\"prdtypecode\\\"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"overlay = overlay_heatmap_on_image(pil_image, cam_up[0], alpha=0.65)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, axes = plt.subplots(1, 4, figsize=(22, 5), facecolor=\\\"white\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"axes[0].imshow(pil_image)\\n\",\n",
    "    \"axes[0].set_title(\\\"Original Image\\\")\\n\",\n",
    "    \"axes[0].axis(\\\"off\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"axes[1].imshow(cam_patch[0], cmap=\\\"jet\\\")\\n\",\n",
    "    \"axes[1].set_title(\\\"Raw Patch CAM\\\")\\n\",\n",
    "    \"axes[1].axis(\\\"off\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"axes[2].imshow(overlay)\\n\",\n",
    "    \"axes[2].set_title(\\\"Overlay Grad-CAM\\\")\\n\",\n",
    "    \"axes[2].axis(\\\"off\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"axes[3].bar([\\\"Text\\\", \\\"Vision\\\"], [text_contribution, vision_contribution])\\n\",\n",
    "    \"axes[3].set_ylim(0, 1)\\n\",\n",
    "    \"axes[3].set_title(\\\"Gate Contribution\\\")\\n\",\n",
    "    \"axes[3].set_ylabel(\\\"Weight\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.suptitle(\\n\",\n",
    "    \"    f\\\"True: {true_prdtypecode} | Pred: {pred_prdtypecode} | Confidence: {confidence:.4f}\\\",\\n\",\n",
    "    \"    fontsize=12\\n\",\n",
    "    \")\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"figure_path = GRADCAM_DIR / f\\\"gradcam_debug_sample_{SAMPLE_INDEX}.png\\\"\\n\",\n",
    "    \"fig.savefig(figure_path, dpi=300, bbox_inches=\\\"tight\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"result = {\\n\",\n",
    "    \"    \\\"sample_index\\\": int(SAMPLE_INDEX),\\n\",\n",
    "    \"    \\\"image_path\\\": str(image_path),\\n\",\n",
