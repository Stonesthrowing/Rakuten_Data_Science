    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"import json\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"from torch.utils.data import Dataset, DataLoader\\n\",\n",
    "    \"\\n\",\n",
    "    \"from transformers import CamembertModel, AutoTokenizer, CLIPVisionModel, CLIPProcessor\\n\",\n",
    "    \"from sklearn.metrics import accuracy_score, f1_score, classification_report\\n\",\n",
    "    \"from tqdm import tqdm\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# CONFIG\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"DEVICE = torch.device(\\\"mps\\\" if torch.backends.mps.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"BATCH_SIZE = 16\\n\",\n",
    "    \"MAX_EPOCHS = 30\\n\",\n",
    "    \"EARLY_STOPPING_PATIENCE = 5\\n\",\n",
    "    \"ACCUM_STEPS = 2\\n\",\n",
    "    \"\\n\",\n",
    "    \"BACKBONE_LR = 2e-6\\n\",\n",
    "    \"CLASSIFIER_LR = 5e-5\\n\",\n",
    "    \"\\n\",\n",
    "    \"MAX_TEXT_LEN = 128\\n\",\n",
    "    \"\\n\",\n",
    "    \"CAMEMBERT_ID = \\\"camembert-base\\\"\\n\",\n",
    "    \"CLIP_ID = \\\"openai/clip-vit-base-patch32\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# PATHS\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent.parent\\n\",\n",
    "    \"DATA_DIR = BASE_DIR / \\\"data\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_DIR / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"RUN_NAME = \\\"mm_camembert_clip_gated_fusion_frozen\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR = BASE_DIR / \\\"outputs\\\" / RUN_NAME\\n\",\n",
    "    \"OUTPUT_DIR.mkdir(exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# LOAD DATA\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"train_df = pd.read_csv(SPLIT_DIR / \\\"train_split.csv\\\")\\n\",\n",
    "    \"val_df = pd.read_csv(SPLIT_DIR / \\\"val_split.csv\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(SPLIT_DIR / \\\"label2id.json\\\") as f:\\n\",\n",
    "    \"    label2id = {int(k): int(v) for k, v in json.load(f).items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# TOKENIZER / PROCESSOR\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"tokenizer = AutoTokenizer.from_pretrained(CAMEMBERT_ID)\\n\",\n",
    "    \"processor = CLIPProcessor.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# DATASET\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"class RakutenDataset(Dataset):\\n\",\n",
    "    \"    def __init__(self, df):\\n\",\n",
    "    \"        self.df = df.reset_index(drop=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __len__(self):\\n\",\n",
    "    \"        return len(self.df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __getitem__(self, idx):\\n\",\n",
    "    \"        row = self.df.iloc[idx]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        img_path = IMAGE_DIR / f\\\"image_{row['imageid']}_product_{row['productid']}.jpg\\\"\\n\",\n",
    "    \"        image = Image.open(img_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        text = f\\\"{row.get('designation','')} {row.get('description','')}\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        txt = tokenizer(\\n\",\n",
    "    \"            text,\\n\",\n",
    "    \"            padding=\\\"max_length\\\",\\n\",\n",
    "    \"            truncation=True,\\n\",\n",
    "    \"            max_length=MAX_TEXT_LEN,\\n\",\n",
    "    \"            return_tensors=\\\"pt\\\"\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        img = processor(images=image, return_tensors=\\\"pt\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            \\\"input_ids\\\": txt[\\\"input_ids\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"attention_mask\\\": txt[\\\"attention_mask\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"pixel_values\\\": img[\\\"pixel_values\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"labels\\\": torch.tensor(label2id[int(row[\\\"prdtypecode\\\"])])\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_loader = DataLoader(RakutenDataset(train_df), batch_size=BATCH_SIZE, shuffle=True)\\n\",\n",
    "    \"val_loader = DataLoader(RakutenDataset(val_df), batch_size=BATCH_SIZE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# MODEL (GATED)\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"class FusionModel(nn.Module):\\n\",\n",
    "    \"    def __init__(self, num_classes):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.text = CamembertModel.from_pretrained(CAMEMBERT_ID)\\n\",\n",
    "    \"        self.vision = CLIPVisionModel.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"        self.debug_done = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.gate = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(1536, 512),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Linear(512, 768),\\n\",\n",
    "    \"            nn.Sigmoid()\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.classifier = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(2304, 512),\\n\",\n",
    "    \"            nn.BatchNorm1d(512),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Dropout(0.3),\\n\",\n",
    "    \"            nn.Linear(512, num_classes)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, i, a, p):\\n\",\n",
    "    \"        t = self.text(input_ids=i, attention_mask=a).pooler_output\\n\",\n",
    "    \"        v = self.vision(pixel_values=p).pooler_output\\n\",\n",
    "    \"\\n\",\n",
    "    \"        t = t / t.norm(dim=-1, keepdim=True).clamp(min=1e-12)\\n\",\n",
    "    \"        v = v / v.norm(dim=-1, keepdim=True).clamp(min=1e-12)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        fusion = torch.cat([t, v], dim=1)\\n\",\n",
    "    \"        g = self.gate(fusion)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        fused = g * v + (1 - g) * t\\n\",\n",
    "    \"        final = torch.cat([fused, t, v], dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if not self.debug_done:\\n\",\n",
    "    \"            print(\\\"t shape:\\\", t.shape)\\n\",\n",
    "    \"            print(\\\"v shape:\\\", v.shape)\\n\",\n",
    "    \"            print(\\\"fusion shape:\\\", fusion.shape)\\n\",\n",
    "    \"            print(\\\"g shape:\\\", g.shape)\\n\",\n",
    "    \"            print(\\\"final shape:\\\", final.shape)\\n\",\n",
    "    \"            self.debug_done = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return self.classifier(final)\\n\",\n",
    "    \"\\n\",\n",
    "    \"model = FusionModel(num_classes=len(label2id)).to(DEVICE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# OPTIMIZER\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"optimizer = torch.optim.AdamW([\\n\",\n",
    "    \"    {\\\"params\\\": [p for n,p in model.named_parameters() if \\\"classifier\\\" not in n], \\\"lr\\\": BACKBONE_LR},\\n\",\n",
    "    \"    {\\\"params\\\": model.classifier.parameters(), \\\"lr\\\": CLASSIFIER_LR}\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"criterion = nn.CrossEntropyLoss()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# TRAIN FUNCTION\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"def run_epoch(loader, train=True):\\n\",\n",
    "    \"    model.train() if train else model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    all_preds, all_true, all_logits = [], [], []\\n\",\n",
    "    \"    total_loss = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for step, batch in enumerate(tqdm(loader)):\\n\",\n",
    "    \"        i = batch[\\\"input_ids\\\"].to(DEVICE)\\n\",\n",
    "    \"        a = batch[\\\"attention_mask\\\"].to(DEVICE)\\n\",\n",
    "    \"        p = batch[\\\"pixel_values\\\"].to(DEVICE)\\n\",\n",
    "    \"        y = batch[\\\"labels\\\"].to(DEVICE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with torch.set_grad_enabled(train):\\n\",\n",
    "    \"            logits = model(i, a, p)\\n\",\n",
    "    \"            loss = criterion(logits, y)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if train:\\n\",\n",
    "    \"                (loss / ACCUM_STEPS).backward()\\n\",\n",
    "    \"                if step % ACCUM_STEPS == 0:\\n\",\n",
    "    \"                    optimizer.step()\\n\",\n",
    "    \"                    optimizer.zero_grad()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        total_loss += loss.item() * y.size(0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        preds = torch.argmax(logits, 1).cpu().numpy()\\n\",\n",
    "    \"        all_preds.extend(preds)\\n\",\n",
    "    \"        all_true.extend(y.cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if not train:\\n\",\n",
    "    \"            all_logits.append(logits.detach().cpu().numpy())\\n\",\n",
    "    \"\\n\",\n",
    "    \"    loss = total_loss / len(loader.dataset)\\n\",\n",
    "    \"    acc = accuracy_score(all_true, all_preds)\\n\",\n",
    "    \"    f1 = f1_score(all_true, all_preds, average=\\\"macro\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    logits_out = np.concatenate(all_logits) if not train else None\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return loss, acc, f1, logits_out, all_true, all_preds\\n\",\n",
    "    \"\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"# TRAIN LOOP\\n\",\n",
    "    \"# =====================\\n\",\n",
    "    \"best_f1 = 0\\n\",\n",
    "    \"early = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"for epoch in range(1, MAX_EPOCHS+1):\\n\",\n",
    "    \"\\n\",\n",
    "    \"    t_loss, t_acc, t_f1, _, _, _ = run_epoch(train_loader, True)\\n\",\n",
    "    \"    v_loss, v_acc, v_f1, v_logits, y_true, y_pred = run_epoch(val_loader, False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Epoch {epoch} | Val F1: {v_f1:.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if v_f1 > best_f1:\\n\",\n",
    "    \"        best_f1 = v_f1\\n\",\n",
    "    \"        early = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        torch.save(model.state_dict(), OUTPUT_DIR / \\\"best_model.pt\\\")\\n\",\n",
    "    \"        np.save(OUTPUT_DIR / \\\"multimodal_logits.npy\\\", v_logits)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        early += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if early >= EARLY_STOPPING_PATIENCE:\\n\",\n",
    "    \"        print(\\\"Early stopping\\\")\\n\",\n",
    "    \"        break\\n\"\n",
    "   ],\n",
