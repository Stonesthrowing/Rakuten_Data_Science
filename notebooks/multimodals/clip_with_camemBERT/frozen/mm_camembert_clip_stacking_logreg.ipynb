    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-04-13T13:16:20.174869Z\",\n",
    "     \"start_time\": \"2026-04-13T13:16:17.694967Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import json\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import joblib\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from sklearn.linear_model import LogisticRegression\\n\",\n",
    "    \"from sklearn.metrics import f1_score, classification_report, accuracy_score\\n\",\n",
    "    \"\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent.parent\\n\",\n",
    "    \"\\n\",\n",
    "    \"OUTPUT_DIR = BASE_DIR / \\\"outputs\\\"\\n\",\n",
    "    \"MODEL_DIR = BASE_DIR / \\\"outputs\\\" / \\\"mm_camembert_clip_gatedfusion_frozen\\\"\\n\",\n",
    "    \"SPLIT_DIR = OUTPUT_DIR / \\\"image_modeling\\\"\\n\",\n",
    "    \"MULTI_PATH = OUTPUT_DIR / \\\"multimodal_logits.npy\\\"\\n\",\n",
    "    \"TEXT_PATH = MODEL_DIR  / \\\"y_logits_camembert_run2_epochs3.npy\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"STACK_MODEL_PATH = OUTPUT_DIR / \\\"final_stacking_model.pkl\\\"\\n\",\n",
    "    \"STACK_FEATURES_PATH = OUTPUT_DIR / \\\"stacking_features.npy\\\"\\n\",\n",
    "    \"STACK_PRED_PATH = OUTPUT_DIR / \\\"stacking_predictions.npy\\\"\\n\",\n",
    "    \"STACK_REPORT_PATH = OUTPUT_DIR / \\\"stacking_report.csv\\\"\\n\",\n",
    "    \"STACK_METADATA_PATH = OUTPUT_DIR / \\\"stacking_metadata.json\\\"\\n\",\n",
    "    \"STACK_PROBA_PATH = OUTPUT_DIR / \\\"stacking_probabilities.npy\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"multi_logits = np.load(MULTI_PATH)\\n\",\n",
    "    \"text_logits = np.load(TEXT_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"multimodal logits shape:\\\", multi_logits.shape)\\n\",\n",
    "    \"print(\\\"text logits shape      :\\\", text_logits.shape)\\n\",\n",
    "    \"\\n\",\n",
    "    \"if multi_logits.shape != text_logits.shape:\\n\",\n",
    "    \"    raise ValueError(\\n\",\n",
    "    \"        f\\\"Shape mismatch: multimodal={multi_logits.shape}, text={text_logits.shape}\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_df = pd.read_csv(SPLIT_DIR / \\\"val_split.csv\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(SPLIT_DIR / \\\"label2id.json\\\", \\\"r\\\") as f:\\n\",\n",
    "    \"    label2id = {int(k): int(v) for k, v in json.load(f).items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"y_true = val_df[\\\"prdtypecode\\\"].map(label2id).to_numpy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"if len(y_true) != multi_logits.shape[0]:\\n\",\n",
    "    \"    raise ValueError(\\n\",\n",
    "    \"        f\\\"Validation length mismatch: y_true={len(y_true)}, logits={multi_logits.shape[0]}\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"# Stacking input features\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"# Burada iki modelin logitslerini yan yana koyuyoruz.\\n\",\n",
    "    \"# 27 class + 27 class = 54 feature\\n\",\n",
    "    \"X = np.concatenate([multi_logits, text_logits], axis=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"stacking feature shape :\\\", X.shape)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"# Final stacking model\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"stack_model = LogisticRegression(\\n\",\n",
    "    \"    max_iter=3000,\\n\",\n",
    "    \"    solver=\\\"lbfgs\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"stack_model.fit(X, y_true)\\n\",\n",
    "    \"\\n\",\n",
    "    \"pred = stack_model.predict(X)\\n\",\n",
    "    \"proba = stack_model.predict_proba(X)\\n\",\n",
    "    \"\\n\",\n",
    "    \"macro_f1 = f1_score(y_true, pred, average=\\\"macro\\\")\\n\",\n",
    "    \"acc = accuracy_score(y_true, pred)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nFINAL STACKING RESULTS\\\")\\n\",\n",
    "    \"print(\\\"Accuracy :\\\", round(acc, 6))\\n\",\n",
    "    \"print(\\\"Macro F1 :\\\", round(macro_f1, 6))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"# Save artifacts\\n\",\n",
    "    \"# ============================================================\\n\",\n",
    "    \"joblib.dump(stack_model, STACK_MODEL_PATH)\\n\",\n",
    "    \"np.save(STACK_FEATURES_PATH, X)\\n\",\n",
    "    \"np.save(STACK_PRED_PATH, pred)\\n\",\n",
    "    \"np.save(STACK_PROBA_PATH, proba)\\n\",\n",
    "    \"\\n\",\n",
    "    \"report_df = pd.DataFrame(\\n\",\n",
    "    \"    classification_report(y_true, pred, output_dict=True, zero_division=0)\\n\",\n",
    "    \").transpose()\\n\",\n",
    "    \"report_df.to_csv(STACK_REPORT_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(STACK_METADATA_PATH, \\\"w\\\") as f:\\n\",\n",
    "    \"    json.dump(\\n\",\n",
    "    \"        {\\n\",\n",
    "    \"            \\\"model_type\\\": \\\"LogisticRegression_stacking\\\",\\n\",\n",
    "    \"            \\\"macro_f1\\\": float(macro_f1),\\n\",\n",
    "    \"            \\\"accuracy\\\": float(acc),\\n\",\n",
    "    \"            \\\"multimodal_shape\\\": list(multi_logits.shape),\\n\",\n",
    "    \"            \\\"text_shape\\\": list(text_logits.shape),\\n\",\n",
    "    \"            \\\"stacking_feature_shape\\\": list(X.shape),\\n\",\n",
    "    \"        },\\n\",\n",
    "    \"        f,\\n\",\n",
    "    \"        indent=2\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"\\\\nSaved:\\\")\\n\",\n",
    "    \"print(STACK_MODEL_PATH)\\n\",\n",
    "    \"print(STACK_FEATURES_PATH)\\n\",\n",
    "    \"print(STACK_PRED_PATH)\\n\",\n",
    "    \"print(STACK_PROBA_PATH)\\n\",\n",
    "    \"print(STACK_REPORT_PATH)\\n\",\n",
    "    \"print(STACK_METADATA_PATH)\"\n",
    "   ],\n",
    "   \"id\": \"e2a16b71dea92e97\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"multimodal logits shape: (16984, 27)\\n\",\n",
    "      \"text logits shape      : (16984, 27)\\n\",\n",
    "      \"stacking feature shape : (16984, 54)\\n\",\n",
    "      \"\\n\",\n",
    "      \"FINAL STACKING RESULTS\\n\",\n",
    "      \"Accuracy : 0.916686\\n\",\n",
    "      \"Macro F1 : 0.907615\\n\",\n",
    "      \"\\n\",\n",
    "      \"Saved:\\n\",\n",
