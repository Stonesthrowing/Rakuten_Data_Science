    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"import json\\n\",\n",
    "    \"import random\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"from PIL import Image\\n\",\n",
    "    \"\\n\",\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn as nn\\n\",\n",
    "    \"import torch.nn.functional as F\\n\",\n",
    "    \"from torch.utils.data import Dataset, DataLoader\\n\",\n",
    "    \"from torchvision import transforms\\n\",\n",
    "    \"\\n\",\n",
    "    \"from transformers import CamembertModel, AutoTokenizer, CLIPVisionModel, CLIPProcessor\\n\",\n",
    "    \"from sklearn.metrics import accuracy_score, f1_score, classification_report\\n\",\n",
    "    \"from tqdm import tqdm\\n\",\n",
    "    \"\\n\",\n",
    "    \"SEED = 42\\n\",\n",
    "    \"random.seed(SEED)\\n\",\n",
    "    \"np.random.seed(SEED)\\n\",\n",
    "    \"torch.manual_seed(SEED)\\n\",\n",
    "    \"\\n\",\n",
    "    \"DEVICE = torch.device(\\\"mps\\\" if torch.backends.mps.is_available() else \\\"cpu\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"BATCH_SIZE = 16\\n\",\n",
    "    \"ACCUM_STEPS = 2\\n\",\n",
    "    \"MAX_TEXT_LEN = 128\\n\",\n",
    "    \"NUM_WORKERS = 0\\n\",\n",
    "    \"EARLY_STOPPING_PATIENCE = 6\\n\",\n",
    "    \"RESUME = True\\n\",\n",
    "    \"WEIGHT_DECAY = 1e-4\\n\",\n",
    "    \"LABEL_SMOOTHING = 0.1\\n\",\n",
    "    \"PROJECTION_DIM = 512\\n\",\n",
    "    \"\\n\",\n",
    "    \"CAMEMBERT_ID = \\\"camembert-base\\\"\\n\",\n",
    "    \"CLIP_ID = \\\"openai/clip-vit-base-patch32\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"STAGE_CONFIGS = [\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"name\\\": \\\"stage1_head_only\\\",\\n\",\n",
    "    \"        \\\"epochs\\\": 3,\\n\",\n",
    "    \"        \\\"text_lr\\\": 0.0,\\n\",\n",
    "    \"        \\\"vision_lr\\\": 0.0,\\n\",\n",
    "    \"        \\\"projection_lr\\\": 5e-4,\\n\",\n",
    "    \"        \\\"gate_lr\\\": 5e-4,\\n\",\n",
    "    \"        \\\"classifier_lr\\\": 5e-4\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"name\\\": \\\"stage2_partial_unfreeze\\\",\\n\",\n",
    "    \"        \\\"epochs\\\": 4,\\n\",\n",
    "    \"        \\\"text_lr\\\": 2e-6,\\n\",\n",
    "    \"        \\\"vision_lr\\\": 2e-6,\\n\",\n",
    "    \"        \\\"projection_lr\\\": 1e-4,\\n\",\n",
    "    \"        \\\"gate_lr\\\": 1e-4,\\n\",\n",
    "    \"        \\\"classifier_lr\\\": 1e-4\\n\",\n",
    "    \"    },\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"        \\\"name\\\": \\\"stage3_full_unfreeze\\\",\\n\",\n",
    "    \"        \\\"epochs\\\": 8,\\n\",\n",
    "    \"        \\\"text_lr\\\": 1e-6,\\n\",\n",
    "    \"        \\\"vision_lr\\\": 1e-6,\\n\",\n",
    "    \"        \\\"projection_lr\\\": 5e-5,\\n\",\n",
    "    \"        \\\"gate_lr\\\": 5e-5,\\n\",\n",
    "    \"        \\\"classifier_lr\\\": 5e-5\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"BASE_DIR = Path.cwd().parent.parent.parent.parent\\n\",\n",
    "    \"DATA_RAW = BASE_DIR / \\\"data\\\" / \\\"raw\\\"\\n\",\n",
    "    \"IMAGE_DIR = DATA_RAW / \\\"images\\\" / \\\"image_train\\\"\\n\",\n",
    "    \"SPLIT_DIR = BASE_DIR / \\\"outputs\\\" / \\\"image_modeling\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"RUN_NAME = \\\"multimodal_camembert_clip_proj_gate_aug_resume\\\"\\n\",\n",
    "    \"OUTPUT_DIR = BASE_DIR / \\\"outputs\\\" / RUN_NAME\\n\",\n",
    "    \"OUTPUT_DIR.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"LAST_CHECKPOINT_PATH = OUTPUT_DIR / \\\"last_checkpoint.pt\\\"\\n\",\n",
    "    \"BEST_CHECKPOINT_PATH = OUTPUT_DIR / \\\"best_checkpoint.pt\\\"\\n\",\n",
    "    \"BEST_MODEL_PATH = OUTPUT_DIR / \\\"best_model_state_dict.pt\\\"\\n\",\n",
    "    \"BEST_VAL_LOGITS_PATH = OUTPUT_DIR / \\\"best_val_logits.npy\\\"\\n\",\n",
    "    \"BEST_VAL_GATE_PATH = OUTPUT_DIR / \\\"best_val_gate_weights.npy\\\"\\n\",\n",
    "    \"BEST_VAL_PRED_PATH = OUTPUT_DIR / \\\"best_val_predictions.csv\\\"\\n\",\n",
    "    \"HISTORY_CSV_PATH = OUTPUT_DIR / \\\"training_history.csv\\\"\\n\",\n",
    "    \"PLOT_PATH = OUTPUT_DIR / \\\"metrics_curves.png\\\"\\n\",\n",
    "    \"BEST_REPORT_PATH = OUTPUT_DIR / \\\"best_classification_report.txt\\\"\\n\",\n",
    "    \"BEST_REPORT_CSV_PATH = OUTPUT_DIR / \\\"best_classification_report.csv\\\"\\n\",\n",
    "    \"BEST_METADATA_PATH = OUTPUT_DIR / \\\"best_metadata.json\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_df = pd.read_csv(SPLIT_DIR / \\\"train_split.csv\\\")\\n\",\n",
    "    \"val_df = pd.read_csv(SPLIT_DIR / \\\"val_split.csv\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"with open(SPLIT_DIR / \\\"label2id.json\\\", \\\"r\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"    raw_label2id = json.load(f)\\n\",\n",
    "    \"    label2id = {int(k): int(v) for k, v in raw_label2id.items()}\\n\",\n",
    "    \"\\n\",\n",
    "    \"id2label = {v: k for k, v in label2id.items()}\\n\",\n",
    "    \"NUM_CLASSES = len(label2id)\\n\",\n",
    "    \"\\n\",\n",
    "    \"tokenizer = AutoTokenizer.from_pretrained(CAMEMBERT_ID)\\n\",\n",
    "    \"processor = CLIPProcessor.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_transforms = transforms.Compose([\\n\",\n",
    "    \"    transforms.RandomHorizontalFlip(p=0.5),\\n\",\n",
    "    \"    transforms.ColorJitter(brightness=0.05, contrast=0.05, saturation=0.05),\\n\",\n",
    "    \"    transforms.RandomAffine(degrees=5, translate=(0.03, 0.03), scale=(0.97, 1.03))\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_transforms = None\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class RakutenDataset(Dataset):\\n\",\n",
    "    \"    def __init__(self, df, transform=None):\\n\",\n",
    "    \"        self.df = df.reset_index(drop=True)\\n\",\n",
    "    \"        self.transform = transform\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __len__(self):\\n\",\n",
    "    \"        return len(self.df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def __getitem__(self, idx):\\n\",\n",
    "    \"        row = self.df.iloc[idx]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        img_path = IMAGE_DIR / f\\\"image_{row['imageid']}_product_{row['productid']}.jpg\\\"\\n\",\n",
    "    \"        image = Image.open(img_path).convert(\\\"RGB\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if self.transform is not None:\\n\",\n",
    "    \"            image = self.transform(image)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        designation = \\\"\\\" if pd.isna(row.get(\\\"designation\\\", \\\"\\\")) else str(row.get(\\\"designation\\\", \\\"\\\"))\\n\",\n",
    "    \"        description = \\\"\\\" if pd.isna(row.get(\\\"description\\\", \\\"\\\")) else str(row.get(\\\"description\\\", \\\"\\\"))\\n\",\n",
    "    \"        text = f\\\"{designation} {description}\\\".strip()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        txt = tokenizer(\\n\",\n",
    "    \"            text,\\n\",\n",
    "    \"            padding=\\\"max_length\\\",\\n\",\n",
    "    \"            truncation=True,\\n\",\n",
    "    \"            max_length=MAX_TEXT_LEN,\\n\",\n",
    "    \"            return_tensors=\\\"pt\\\"\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        img = processor(images=image, return_tensors=\\\"pt\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            \\\"input_ids\\\": txt[\\\"input_ids\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"attention_mask\\\": txt[\\\"attention_mask\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"pixel_values\\\": img[\\\"pixel_values\\\"].squeeze(0),\\n\",\n",
    "    \"            \\\"labels\\\": torch.tensor(label2id[int(row[\\\"prdtypecode\\\"])], dtype=torch.long),\\n\",\n",
    "    \"            \\\"imageid\\\": int(row[\\\"imageid\\\"]),\\n\",\n",
    "    \"            \\\"productid\\\": int(row[\\\"productid\\\"]),\\n\",\n",
    "    \"            \\\"prdtypecode\\\": int(row[\\\"prdtypecode\\\"])\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"train_loader = DataLoader(\\n\",\n",
    "    \"    RakutenDataset(train_df, transform=train_transforms),\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=True,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"val_loader = DataLoader(\\n\",\n",
    "    \"    RakutenDataset(val_df, transform=val_transforms),\\n\",\n",
    "    \"    batch_size=BATCH_SIZE,\\n\",\n",
    "    \"    shuffle=False,\\n\",\n",
    "    \"    num_workers=NUM_WORKERS\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"class FusionModel(nn.Module):\\n\",\n",
    "    \"    def __init__(self, num_classes, projection_dim=512):\\n\",\n",
    "    \"        super().__init__()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.text_backbone = CamembertModel.from_pretrained(CAMEMBERT_ID)\\n\",\n",
    "    \"        self.vision_backbone = CLIPVisionModel.from_pretrained(CLIP_ID)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.text_projection = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(768, projection_dim),\\n\",\n",
    "    \"            nn.LayerNorm(projection_dim),\\n\",\n",
    "    \"            nn.GELU()\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.vision_projection = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(768, projection_dim),\\n\",\n",
    "    \"            nn.LayerNorm(projection_dim),\\n\",\n",
    "    \"            nn.GELU()\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.gate = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(projection_dim * 2, projection_dim),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Dropout(0.2),\\n\",\n",
    "    \"            nn.Linear(projection_dim, 2)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.classifier = nn.Sequential(\\n\",\n",
    "    \"            nn.Linear(projection_dim, projection_dim),\\n\",\n",
    "    \"            nn.BatchNorm1d(projection_dim),\\n\",\n",
    "    \"            nn.ReLU(),\\n\",\n",
    "    \"            nn.Dropout(0.3),\\n\",\n",
    "    \"            nn.Linear(projection_dim, num_classes)\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        self.debug_done = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, input_ids, attention_mask, pixel_values):\\n\",\n",
    "    \"        text_outputs = self.text_backbone(\\n\",\n",
    "    \"            input_ids=input_ids,\\n\",\n",
    "    \"            attention_mask=attention_mask\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"        vision_outputs = self.vision_backbone(\\n\",\n",
    "    \"            pixel_values=pixel_values\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        t_feat = text_outputs.last_hidden_state[:, 0]\\n\",\n",
    "    \"        v_feat = vision_outputs.pooler_output\\n\",\n",
    "    \"\\n\",\n",
    "    \"        t_proj = self.text_projection(t_feat)\\n\",\n",
    "    \"        v_proj = self.vision_projection(v_feat)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        t_proj = F.normalize(t_proj, p=2, dim=1)\\n\",\n",
    "    \"        v_proj = F.normalize(v_proj, p=2, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        gate_input = torch.cat([t_proj, v_proj], dim=1)\\n\",\n",
    "    \"        gate_logits = self.gate(gate_input)\\n\",\n",
    "    \"        gate_weights = torch.softmax(gate_logits, dim=1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        w_text = gate_weights[:, 0].unsqueeze(1)\\n\",\n",
    "    \"        w_image = gate_weights[:, 1].unsqueeze(1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        fused = (w_text * t_proj) + (w_image * v_proj)\\n\",\n",
    "    \"        logits = self.classifier(fused)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if not self.debug_done:\\n\",\n",
    "    \"            print(\\\"text raw shape:\\\", t_feat.shape)\\n\",\n",
    "    \"            print(\\\"vision raw shape:\\\", v_feat.shape)\\n\",\n",
    "    \"            print(\\\"text proj shape:\\\", t_proj.shape)\\n\",\n",
    "    \"            print(\\\"vision proj shape:\\\", v_proj.shape)\\n\",\n",
    "    \"            print(\\\"gate input shape:\\\", gate_input.shape)\\n\",\n",
    "    \"            print(\\\"gate weights shape:\\\", gate_weights.shape)\\n\",\n",
    "    \"            print(\\\"fused shape:\\\", fused.shape)\\n\",\n",
    "    \"            print(\\\"logits shape:\\\", logits.shape)\\n\",\n",
    "    \"            self.debug_done = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return logits, gate_weights\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"model = FusionModel(num_classes=NUM_CLASSES, projection_dim=PROJECTION_DIM).to(DEVICE)\\n\",\n",
    "    \"criterion = nn.CrossEntropyLoss(label_smoothing=LABEL_SMOOTHING)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def freeze_module(module):\\n\",\n",
    "    \"    for p in module.parameters():\\n\",\n",
    "    \"        p.requires_grad = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def unfreeze_module(module):\\n\",\n",
    "    \"    for p in module.parameters():\\n\",\n",
    "    \"        p.requires_grad = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def freeze_all_backbones(model):\\n\",\n",
    "    \"    freeze_module(model.text_backbone)\\n\",\n",
    "    \"    freeze_module(model.vision_backbone)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def unfreeze_last_camembert_layers(model, layer_indices=(10, 11)):\\n\",\n",
    "    \"    for name, p in model.text_backbone.named_parameters():\\n\",\n",
    "    \"        if any(f\\\"encoder.layer.{idx}.\\\" in name for idx in layer_indices):\\n\",\n",
    "    \"            p.requires_grad = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def unfreeze_last_clip_layers(model, layer_indices=(10, 11)):\\n\",\n",
    "    \"    for name, p in model.vision_backbone.named_parameters():\\n\",\n",
    "    \"        if any(f\\\"vision_model.encoder.layers.{idx}.\\\" in name for idx in layer_indices):\\n\",\n",
    "    \"            p.requires_grad = True\\n\",\n",
    "    \"        elif \\\"vision_model.post_layernorm\\\" in name:\\n\",\n",
    "    \"            p.requires_grad = True\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def apply_stage_freezing(model, stage_name):\\n\",\n",
    "    \"    unfreeze_module(model.text_projection)\\n\",\n",
    "    \"    unfreeze_module(model.vision_projection)\\n\",\n",
    "    \"    unfreeze_module(model.gate)\\n\",\n",
    "    \"    unfreeze_module(model.classifier)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if stage_name == \\\"stage1_head_only\\\":\\n\",\n",
    "    \"        freeze_all_backbones(model)\\n\",\n",
    "    \"    elif stage_name == \\\"stage2_partial_unfreeze\\\":\\n\",\n",
    "    \"        freeze_all_backbones(model)\\n\",\n",
    "    \"        unfreeze_last_camembert_layers(model, layer_indices=(10, 11))\\n\",\n",
    "    \"        unfreeze_last_clip_layers(model, layer_indices=(10, 11))\\n\",\n",
    "    \"    elif stage_name == \\\"stage3_full_unfreeze\\\":\\n\",\n",
    "    \"        unfreeze_module(model)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        raise ValueError(f\\\"Unknown stage name: {stage_name}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_optimizer(model, text_lr, vision_lr, projection_lr, gate_lr, classifier_lr):\\n\",\n",
    "    \"    text_params = []\\n\",\n",
    "    \"    vision_params = []\\n\",\n",
    "    \"    projection_params = []\\n\",\n",
    "    \"    gate_params = []\\n\",\n",
    "    \"    classifier_params = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for name, p in model.named_parameters():\\n\",\n",
    "    \"        if not p.requires_grad:\\n\",\n",
    "    \"            continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if name.startswith(\\\"text_backbone.\\\"):\\n\",\n",
    "    \"            text_params.append(p)\\n\",\n",
    "    \"        elif name.startswith(\\\"vision_backbone.\\\"):\\n\",\n",
    "    \"            vision_params.append(p)\\n\",\n",
    "    \"        elif name.startswith(\\\"text_projection.\\\") or name.startswith(\\\"vision_projection.\\\"):\\n\",\n",
    "    \"            projection_params.append(p)\\n\",\n",
    "    \"        elif name.startswith(\\\"gate.\\\"):\\n\",\n",
    "    \"            gate_params.append(p)\\n\",\n",
    "    \"        elif name.startswith(\\\"classifier.\\\"):\\n\",\n",
    "    \"            classifier_params.append(p)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    param_groups = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if text_params and text_lr > 0:\\n\",\n",
    "    \"        param_groups.append({\\\"params\\\": text_params, \\\"lr\\\": text_lr})\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if vision_params and vision_lr > 0:\\n\",\n",
    "    \"        param_groups.append({\\\"params\\\": vision_params, \\\"lr\\\": vision_lr})\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if projection_params and projection_lr > 0:\\n\",\n",
    "    \"        param_groups.append({\\\"params\\\": projection_params, \\\"lr\\\": projection_lr})\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if gate_params and gate_lr > 0:\\n\",\n",
    "    \"        param_groups.append({\\\"params\\\": gate_params, \\\"lr\\\": gate_lr})\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if classifier_params and classifier_lr > 0:\\n\",\n",
    "    \"        param_groups.append({\\\"params\\\": classifier_params, \\\"lr\\\": classifier_lr})\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return torch.optim.AdamW(param_groups, weight_decay=WEIGHT_DECAY)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def build_advanced_optimizer(model, stage_cfg):\\n\",\n",
    "    \"    optimizer = build_optimizer(\\n\",\n",
    "    \"        model=model,\\n\",\n",
    "    \"        text_lr=stage_cfg[\\\"text_lr\\\"],\\n\",\n",
    "    \"        vision_lr=stage_cfg[\\\"vision_lr\\\"],\\n\",\n",
    "    \"        projection_lr=stage_cfg[\\\"projection_lr\\\"],\\n\",\n",
    "    \"        gate_lr=stage_cfg[\\\"gate_lr\\\"],\\n\",\n",
    "    \"        classifier_lr=stage_cfg[\\\"classifier_lr\\\"]\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(\\n\",\n",
    "    \"        optimizer,\\n\",\n",
    "    \"        mode=\\\"max\\\",\\n\",\n",
    "    \"        factor=0.5,\\n\",\n",
    "    \"        patience=2,\\n\",\n",
    "    \"        threshold=1e-3,\\n\",\n",
    "    \"        threshold_mode=\\\"rel\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    return optimizer, scheduler\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def count_trainable_params(model):\\n\",\n",
    "    \"    trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\\n\",\n",
    "    \"    total = sum(p.numel() for p in model.parameters())\\n\",\n",
    "    \"    return trainable, total\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def run_epoch(model, loader, optimizer=None, train=True):\\n\",\n",
    "    \"    if train:\\n\",\n",
    "    \"        model.train()\\n\",\n",
    "    \"        optimizer.zero_grad(set_to_none=True)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        model.eval()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    total_loss = 0.0\\n\",\n",
    "    \"    all_preds = []\\n\",\n",
    "    \"    all_true = []\\n\",\n",
    "    \"    all_logits = []\\n\",\n",
    "    \"    all_gate_weights = []\\n\",\n",
    "    \"    all_rows = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for step, batch in enumerate(tqdm(loader, leave=False), start=1):\\n\",\n",
    "    \"        input_ids = batch[\\\"input_ids\\\"].to(DEVICE)\\n\",\n",
    "    \"        attention_mask = batch[\\\"attention_mask\\\"].to(DEVICE)\\n\",\n",
    "    \"        pixel_values = batch[\\\"pixel_values\\\"].to(DEVICE)\\n\",\n",
    "    \"        labels = batch[\\\"labels\\\"].to(DEVICE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        with torch.set_grad_enabled(train):\\n\",\n",
    "    \"            logits, gate_weights = model(input_ids, attention_mask, pixel_values)\\n\",\n",
    "    \"            loss = criterion(logits, labels)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if train:\\n\",\n",
    "    \"                (loss / ACCUM_STEPS).backward()\\n\",\n",
    "    \"\\n\",\n",
    "    \"                if step % ACCUM_STEPS == 0:\\n\",\n",
    "    \"                    optimizer.step()\\n\",\n",
    "    \"                    optimizer.zero_grad(set_to_none=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        total_loss += loss.item() * labels.size(0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        preds = torch.argmax(logits, dim=1).detach().cpu().numpy()\\n\",\n",
    "    \"        true_np = labels.detach().cpu().numpy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        all_preds.extend(preds)\\n\",\n",
    "    \"        all_true.extend(true_np)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if not train:\\n\",\n",
    "    \"            logits_np = logits.detach().cpu().numpy()\\n\",\n",
    "    \"            gate_np = gate_weights.detach().cpu().numpy()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            all_logits.append(logits_np)\\n\",\n",
    "    \"            all_gate_weights.append(gate_np)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            imageids = batch[\\\"imageid\\\"]\\n\",\n",
    "    \"            productids = batch[\\\"productid\\\"]\\n\",\n",
    "    \"            prdtypecodes = batch[\\\"prdtypecode\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"            for idx in range(len(preds)):\\n\",\n",
    "    \"                pred_label_id = int(preds[idx])\\n\",\n",
    "    \"                true_label_id = int(true_np[idx])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                row = {\\n\",\n",
    "    \"                    \\\"imageid\\\": int(imageids[idx]),\\n\",\n",
    "    \"                    \\\"productid\\\": int(productids[idx]),\\n\",\n",
    "    \"                    \\\"true_prdtypecode\\\": int(prdtypecodes[idx]),\\n\",\n",
    "    \"                    \\\"true_label_id\\\": true_label_id,\\n\",\n",
    "    \"                    \\\"pred_label_id\\\": pred_label_id,\\n\",\n",
    "    \"                    \\\"pred_prdtypecode\\\": int(id2label[pred_label_id]),\\n\",\n",
    "    \"                    \\\"text_weight\\\": float(gate_np[idx, 0]),\\n\",\n",
    "    \"                    \\\"image_weight\\\": float(gate_np[idx, 1])\\n\",\n",
    "    \"                }\\n\",\n",
    "    \"\\n\",\n",
    "    \"                for class_idx in range(logits_np.shape[1]):\\n\",\n",
    "    \"                    row[f\\\"logit_{class_idx}\\\"] = float(logits_np[idx, class_idx])\\n\",\n",
    "    \"\\n\",\n",
    "    \"                all_rows.append(row)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if train and (len(loader) % ACCUM_STEPS != 0):\\n\",\n",
    "    \"        optimizer.step()\\n\",\n",
    "    \"        optimizer.zero_grad(set_to_none=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    epoch_loss = total_loss / len(loader.dataset)\\n\",\n",
    "    \"    epoch_acc = accuracy_score(all_true, all_preds)\\n\",\n",
    "    \"    epoch_f1 = f1_score(all_true, all_preds, average=\\\"macro\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    logits_out = np.concatenate(all_logits, axis=0) if (not train and all_logits) else None\\n\",\n",
    "    \"    gate_out = np.concatenate(all_gate_weights, axis=0) if (not train and all_gate_weights) else None\\n\",\n",
    "    \"    pred_df = pd.DataFrame(all_rows) if not train else None\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return epoch_loss, epoch_acc, epoch_f1, logits_out, gate_out, all_true, all_preds, pred_df\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def save_checkpoint(\\n\",\n",
    "    \"    path,\\n\",\n",
    "    \"    model,\\n\",\n",
    "    \"    optimizer,\\n\",\n",
    "    \"    scheduler,\\n\",\n",
    "    \"    history,\\n\",\n",
    "    \"    global_epoch,\\n\",\n",
    "    \"    stage_idx,\\n\",\n",
    "    \"    local_epoch,\\n\",\n",
    "    \"    best_f1,\\n\",\n",
    "    \"    best_epoch_global,\\n\",\n",
    "    \"    best_stage_name,\\n\",\n",
    "    \"    epochs_without_improvement\\n\",\n",
    "    \"):\\n\",\n",
    "    \"    payload = {\\n\",\n",
    "    \"        \\\"model_state_dict\\\": model.state_dict(),\\n\",\n",
    "    \"        \\\"optimizer_state_dict\\\": optimizer.state_dict() if optimizer is not None else None,\\n\",\n",
    "    \"        \\\"scheduler_state_dict\\\": scheduler.state_dict() if scheduler is not None else None,\\n\",\n",
    "    \"        \\\"history\\\": history,\\n\",\n",
    "    \"        \\\"global_epoch\\\": global_epoch,\\n\",\n",
    "    \"        \\\"stage_idx\\\": stage_idx,\\n\",\n",
    "    \"        \\\"local_epoch\\\": local_epoch,\\n\",\n",
    "    \"        \\\"best_f1\\\": best_f1,\\n\",\n",
    "    \"        \\\"best_epoch_global\\\": best_epoch_global,\\n\",\n",
    "    \"        \\\"best_stage_name\\\": best_stage_name,\\n\",\n",
    "    \"        \\\"epochs_without_improvement\\\": epochs_without_improvement,\\n\",\n",
    "    \"        \\\"seed\\\": SEED,\\n\",\n",
    "    \"        \\\"batch_size\\\": BATCH_SIZE,\\n\",\n",
    "    \"        \\\"accum_steps\\\": ACCUM_STEPS,\\n\",\n",
    "    \"        \\\"max_text_len\\\": MAX_TEXT_LEN,\\n\",\n",
    "    \"        \\\"camembert_id\\\": CAMEMBERT_ID,\\n\",\n",
    "    \"        \\\"clip_id\\\": CLIP_ID,\\n\",\n",
    "    \"        \\\"stage_configs\\\": STAGE_CONFIGS\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"    torch.save(payload, path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def load_checkpoint(path):\\n\",\n",
    "    \"    return torch.load(path, map_location=DEVICE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"def plot_history(history, output_path):\\n\",\n",
    "    \"    if len(history) == 0:\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    df = pd.DataFrame(history)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.figure(figsize=(10, 6))\\n\",\n",
    "    \"    plt.plot(df[\\\"global_epoch\\\"], df[\\\"train_acc\\\"], label=\\\"Train Accuracy\\\")\\n\",\n",
    "    \"    plt.plot(df[\\\"global_epoch\\\"], df[\\\"val_acc\\\"], label=\\\"Validation Accuracy\\\")\\n\",\n",
    "    \"    plt.plot(df[\\\"global_epoch\\\"], df[\\\"train_macro_f1\\\"], label=\\\"Train Macro F1\\\")\\n\",\n",
    "    \"    plt.plot(df[\\\"global_epoch\\\"], df[\\\"val_macro_f1\\\"], label=\\\"Validation Macro F1\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Epoch\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Score\\\")\\n\",\n",
    "    \"    plt.title(\\\"Training Metrics\\\")\\n\",\n",
    "    \"    plt.legend()\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(output_path, dpi=150)\\n\",\n",
    "    \"    plt.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"history = []\\n\",\n",
    "    \"best_f1 = -1.0\\n\",\n",
    "    \"best_epoch_global = -1\\n\",\n",
    "    \"best_stage_name = None\\n\",\n",
    "    \"epochs_without_improvement = 0\\n\",\n",
    "    \"global_epoch = 0\\n\",\n",
    "    \"start_stage_idx = 0\\n\",\n",
    "    \"resume_local_epoch = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"if RESUME and LAST_CHECKPOINT_PATH.exists():\\n\",\n",
    "    \"    print(f\\\"Resuming from checkpoint: {LAST_CHECKPOINT_PATH}\\\")\\n\",\n",
    "    \"    ckpt = load_checkpoint(LAST_CHECKPOINT_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    model.load_state_dict(ckpt[\\\"model_state_dict\\\"])\\n\",\n",
    "    \"    history = ckpt[\\\"history\\\"]\\n\",\n",
    "    \"    global_epoch = ckpt[\\\"global_epoch\\\"]\\n\",\n",
    "    \"    start_stage_idx = ckpt[\\\"stage_idx\\\"]\\n\",\n",
    "    \"    resume_local_epoch = ckpt[\\\"local_epoch\\\"]\\n\",\n",
    "    \"    best_f1 = ckpt[\\\"best_f1\\\"]\\n\",\n",
    "    \"    best_epoch_global = ckpt[\\\"best_epoch_global\\\"]\\n\",\n",
    "    \"    best_stage_name = ckpt[\\\"best_stage_name\\\"]\\n\",\n",
    "    \"    epochs_without_improvement = ckpt[\\\"epochs_without_improvement\\\"]\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    print(\\\"Starting training from scratch\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"stop_training = False\\n\",\n",
    "    \"\\n\",\n",
    "    \"for stage_idx in range(start_stage_idx, len(STAGE_CONFIGS)):\\n\",\n",
    "    \"    stage_cfg = STAGE_CONFIGS[stage_idx]\\n\",\n",
    "    \"    stage_name = stage_cfg[\\\"name\\\"]\\n\",\n",
    "    \"    stage_epochs = stage_cfg[\\\"epochs\\\"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(\\\"\\\\n\\\" + \\\"=\\\" * 80)\\n\",\n",
    "    \"    print(f\\\"Starting {stage_name}\\\")\\n\",\n",
    "    \"    print(\\\"=\\\" * 80)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    apply_stage_freezing(model, stage_name)\\n\",\n",
    "    \"    optimizer, scheduler = build_advanced_optimizer(model, stage_cfg)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if RESUME and LAST_CHECKPOINT_PATH.exists() and stage_idx == start_stage_idx:\\n\",\n",
    "    \"        ckpt = load_checkpoint(LAST_CHECKPOINT_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if ckpt[\\\"optimizer_state_dict\\\"] is not None:\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                optimizer.load_state_dict(ckpt[\\\"optimizer_state_dict\\\"])\\n\",\n",
    "    \"                print(\\\"Optimizer state loaded from checkpoint\\\")\\n\",\n",
    "    \"            except Exception as e:\\n\",\n",
    "    \"                print(f\\\"Optimizer state could not be loaded exactly: {e}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if ckpt.get(\\\"scheduler_state_dict\\\") is not None:\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                scheduler.load_state_dict(ckpt[\\\"scheduler_state_dict\\\"])\\n\",\n",
    "    \"                print(\\\"Scheduler state loaded from checkpoint\\\")\\n\",\n",
    "    \"            except Exception as e:\\n\",\n",
    "    \"                print(f\\\"Scheduler state could not be loaded exactly: {e}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    trainable, total = count_trainable_params(model)\\n\",\n",
    "    \"    print(f\\\"Trainable params: {trainable:,} / {total:,}\\\")\\n\",\n",
    "    \"    print(f\\\"Text LR: {stage_cfg['text_lr']}\\\")\\n\",\n",
    "    \"    print(f\\\"Vision LR: {stage_cfg['vision_lr']}\\\")\\n\",\n",
    "    \"    print(f\\\"Projection LR: {stage_cfg['projection_lr']}\\\")\\n\",\n",
    "    \"    print(f\\\"Gate LR: {stage_cfg['gate_lr']}\\\")\\n\",\n",
    "    \"    print(f\\\"Classifier LR: {stage_cfg['classifier_lr']}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    stage_start_epoch = resume_local_epoch + 1 if stage_idx == start_stage_idx else 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for local_epoch in range(stage_start_epoch, stage_epochs + 1):\\n\",\n",
    "    \"        global_epoch += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        train_loss, train_acc, train_f1, _, _, _, _, _ = run_epoch(\\n\",\n",
    "    \"            model=model,\\n\",\n",
    "    \"            loader=train_loader,\\n\",\n",
    "    \"            optimizer=optimizer,\\n\",\n",
    "    \"            train=True\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        val_loss, val_acc, val_f1, val_logits, val_gate, y_true, y_pred, val_pred_df = run_epoch(\\n\",\n",
    "    \"            model=model,\\n\",\n",
    "    \"            loader=val_loader,\\n\",\n",
    "    \"            optimizer=None,\\n\",\n",
    "    \"            train=False\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        scheduler.step(val_f1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        mean_text_weight = float(val_gate[:, 0].mean()) if val_gate is not None else None\\n\",\n",
    "    \"        mean_image_weight = float(val_gate[:, 1].mean()) if val_gate is not None else None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(\\n\",\n",
    "    \"            f\\\"Epoch {global_epoch:02d} | \\\"\\n\",\n",
    "    \"            f\\\"Stage={stage_name} | \\\"\\n\",\n",
    "    \"            f\\\"train_loss={train_loss:.4f} | \\\"\\n\",\n",
    "    \"            f\\\"train_acc={train_acc:.4f} | \\\"\\n\",\n",
    "    \"            f\\\"train_f1={train_f1:.4f} | \\\"\\n\",\n",
    "    \"            f\\\"val_loss={val_loss:.4f} | \\\"\\n\",\n",
    "    \"            f\\\"val_acc={val_acc:.4f} | \\\"\\n\",\n",
    "    \"            f\\\"val_f1={val_f1:.4f} | \\\"\\n\",\n",
    "    \"            f\\\"mean_text_w={mean_text_weight:.4f} | \\\"\\n\",\n",
    "    \"            f\\\"mean_image_w={mean_image_weight:.4f}\\\"\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        history.append({\\n\",\n",
    "    \"            \\\"global_epoch\\\": global_epoch,\\n\",\n",
    "    \"            \\\"stage_idx\\\": stage_idx,\\n\",\n",
    "    \"            \\\"stage\\\": stage_name,\\n\",\n",
    "    \"            \\\"stage_epoch\\\": local_epoch,\\n\",\n",
    "    \"            \\\"train_loss\\\": train_loss,\\n\",\n",
    "    \"            \\\"train_acc\\\": train_acc,\\n\",\n",
    "    \"            \\\"train_macro_f1\\\": train_f1,\\n\",\n",
    "    \"            \\\"val_loss\\\": val_loss,\\n\",\n",
    "    \"            \\\"val_acc\\\": val_acc,\\n\",\n",
    "    \"            \\\"val_macro_f1\\\": val_f1,\\n\",\n",
    "    \"            \\\"mean_text_weight\\\": mean_text_weight,\\n\",\n",
    "    \"            \\\"mean_image_weight\\\": mean_image_weight,\\n\",\n",
    "    \"            \\\"text_lr\\\": stage_cfg[\\\"text_lr\\\"],\\n\",\n",
    "    \"            \\\"vision_lr\\\": stage_cfg[\\\"vision_lr\\\"],\\n\",\n",
    "    \"            \\\"projection_lr\\\": stage_cfg[\\\"projection_lr\\\"],\\n\",\n",
    "    \"            \\\"gate_lr\\\": stage_cfg[\\\"gate_lr\\\"],\\n\",\n",
    "    \"            \\\"classifier_lr\\\": stage_cfg[\\\"classifier_lr\\\"]\\n\",\n",
    "    \"        })\\n\",\n",
    "    \"\\n\",\n",
    "    \"        pd.DataFrame(history).to_csv(HISTORY_CSV_PATH, index=False)\\n\",\n",
    "    \"        plot_history(history, PLOT_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if val_f1 > best_f1:\\n\",\n",
    "    \"            best_f1 = val_f1\\n\",\n",
    "    \"            best_epoch_global = global_epoch\\n\",\n",
    "    \"            best_stage_name = stage_name\\n\",\n",
    "    \"            epochs_without_improvement = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"            torch.save(model.state_dict(), BEST_MODEL_PATH)\\n\",\n",
    "    \"            np.save(BEST_VAL_LOGITS_PATH, val_logits)\\n\",\n",
    "    \"            np.save(BEST_VAL_GATE_PATH, val_gate)\\n\",\n",
    "    \"            val_pred_df.to_csv(BEST_VAL_PRED_PATH, index=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            report_text = classification_report(y_true, y_pred, digits=4)\\n\",\n",
    "    \"            with open(BEST_REPORT_PATH, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"                f.write(report_text)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            report_dict = classification_report(y_true, y_pred, output_dict=True, zero_division=0)\\n\",\n",
    "    \"            pd.DataFrame(report_dict).transpose().to_csv(BEST_REPORT_CSV_PATH)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            best_metadata = {\\n\",\n",
    "    \"                \\\"best_val_macro_f1\\\": float(best_f1),\\n\",\n",
    "    \"                \\\"best_epoch_global\\\": int(best_epoch_global),\\n\",\n",
    "    \"                \\\"best_stage_name\\\": best_stage_name,\\n\",\n",
    "    \"                \\\"num_classes\\\": int(NUM_CLASSES),\\n\",\n",
    "    \"                \\\"batch_size\\\": int(BATCH_SIZE),\\n\",\n",
    "    \"                \\\"accum_steps\\\": int(ACCUM_STEPS),\\n\",\n",
    "    \"                \\\"max_text_len\\\": int(MAX_TEXT_LEN),\\n\",\n",
    "    \"                \\\"label_smoothing\\\": float(LABEL_SMOOTHING),\\n\",\n",
    "    \"                \\\"projection_dim\\\": int(PROJECTION_DIM),\\n\",\n",
    "    \"                \\\"camembert_id\\\": CAMEMBERT_ID,\\n\",\n",
    "    \"                \\\"clip_id\\\": CLIP_ID,\\n\",\n",
    "    \"                \\\"device\\\": str(DEVICE),\\n\",\n",
    "    \"                \\\"best_val_logits_path\\\": str(BEST_VAL_LOGITS_PATH),\\n\",\n",
    "    \"                \\\"best_val_gate_weights_path\\\": str(BEST_VAL_GATE_PATH),\\n\",\n",
    "    \"                \\\"best_val_predictions_path\\\": str(BEST_VAL_PRED_PATH)\\n\",\n",
    "    \"            }\\n\",\n",
    "    \"\\n\",\n",
    "    \"            with open(BEST_METADATA_PATH, \\\"w\\\", encoding=\\\"utf-8\\\") as f:\\n\",\n",
    "    \"                json.dump(best_metadata, f, indent=2, ensure_ascii=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            save_checkpoint(\\n\",\n",
    "    \"                path=BEST_CHECKPOINT_PATH,\\n\",\n",
    "    \"                model=model,\\n\",\n",
    "    \"                optimizer=optimizer,\\n\",\n",
    "    \"                scheduler=scheduler,\\n\",\n",
    "    \"                history=history,\\n\",\n",
    "    \"                global_epoch=global_epoch,\\n\",\n",
    "    \"                stage_idx=stage_idx,\\n\",\n",
    "    \"                local_epoch=local_epoch,\\n\",\n",
    "    \"                best_f1=best_f1,\\n\",\n",
    "    \"                best_epoch_global=best_epoch_global,\\n\",\n",
    "    \"                best_stage_name=best_stage_name,\\n\",\n",
    "    \"                epochs_without_improvement=epochs_without_improvement\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"            print(f\\\"  -> New best model saved. val_f1={val_f1:.4f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            epochs_without_improvement += 1\\n\",\n",
    "    \"            print(f\\\"  -> No improvement for {epochs_without_improvement} epoch(s)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        save_checkpoint(\\n\",\n",
    "    \"            path=LAST_CHECKPOINT_PATH,\\n\",\n",
    "    \"            model=model,\\n\",\n",
    "    \"            optimizer=optimizer,\\n\",\n",
    "    \"            scheduler=scheduler,\\n\",\n",
    "    \"            history=history,\\n\",\n",
    "    \"            global_epoch=global_epoch,\\n\",\n",
